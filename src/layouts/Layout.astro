---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import NewsModal from '../components/NewsModal.astro';
import PopupAnnouncement from '../components/PopupAnnouncement.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  noPopup?: boolean;
}

const {
  title,
  description = "Leading renewable energy solutions for a sustainable future",
  image = "/Pss.O_Logo.png",
  type = "website",
  noPopup = false,
} = Astro.props;

const canonicalURL = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/Pss.O_Logo.png" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"></noscript>
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <meta name="description" content={description} />
    <meta name="keywords" content="Renewable Energy, Solar Power, Wind Energy, Battery Storage, PSS Powers, I Squared Capital" />
    <meta name="author" content="PSS Powers" />
    <meta name="theme-color" content="#10b981" />
    <meta name="robots" content="index, follow" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- PWA Tags -->
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/Pss.O_Logo.png" />
    <link rel="preload" as="image" href="/Final_Hero_shot_website.jpg" fetchpriority="high" />

    <!-- JSON-LD Schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "PSS Powers",
        "url": "https://www.psspowers.com",
        "logo": "https://www.psspowers.com/Pss.O_Logo.png",
        "description": "Leading provider of renewable energy solutions across Asia, specializing in solar, wind, and energy storage systems.",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Ocean Tower 2 (26th Floor), 75/56 Sukhumvit Soi 19",
          "addressLocality": "Bangkok",
          "addressRegion": "Bangkok",
          "postalCode": "10110",
          "addressCountry": "TH"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+66-2-106-2611",
          "contactType": "customer service",
          "areaServed": "Asia",
          "availableLanguage": "en"
        },
        "sameAs": [
          "https://www.linkedin.com/company/psspowers"
        ]
      }
    </script>

    <title>{title}</title>
  </head>
  <body class="bg-slate-950 text-slate-200 antialiased">
    <Navigation />
    <slot />
    <Footer />
    <NewsModal />
    {!noPopup && <PopupAnnouncement />}
    <script>
      import AOS from 'aos';
      import 'aos/dist/aos.css';
      
      // Preconnect to external domains
      const domains = [
        'https://fonts.googleapis.com',
        'https://fonts.gstatic.com',
        'https://basemaps.cartocdn.com'
      ];
      
      domains.forEach(domain => {
        const link = document.createElement('link');
        link.rel = 'preconnect';
        link.href = domain;
        document.head.appendChild(link);
      });

      // Performance monitoring
      if (typeof window !== 'undefined') {
        window.addEventListener('load', () => {
          // Use Performance Observer for better metrics
          const observer = new PerformanceObserver((list) => {
            list.getEntries().forEach((entry) => {
              console.log(`${entry.name}: ${entry.startTime}ms`);
            });
          });
          
          observer.observe({ entryTypes: ['paint', 'largest-contentful-paint', 'first-input'] });
        });
      }

      document.addEventListener('DOMContentLoaded', () => {
        AOS.init({
          duration: 800,
          once: true,
          disable: window.innerWidth < 768
        });
      });
    </script>
  </body>
</html>