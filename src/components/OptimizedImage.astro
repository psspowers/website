---
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  priority?: boolean;
  aspectRatio?: "16:9" | "4:3" | "1:1";
  sizes?: string;
  fallback?: string;
}

const {
  src,
  alt,
  width,
  height,
  class: className = "",
  priority = false,
  aspectRatio,
  sizes = "(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw",
  fallback = "/pss-logo-black.png",
} = Astro.props;

const resolvedSrc = src || '';

let paddingBottom = "100%";
if (aspectRatio) {
  const [w, h] = aspectRatio.split(":");
  paddingBottom = `${(Number(h) / Number(w)) * 100}%`;
} else if (width && height) {
  paddingBottom = `${(height / width) * 100}%`;
}

const loading = priority ? "eager" : "lazy";
const fetchPriority = priority ? "high" : "auto";
---

<div class={`opt-img-wrap relative overflow-hidden ${className}`} style={`padding-bottom: ${paddingBottom};`}>
  <div class="skeleton absolute inset-0 bg-slate-700"></div>
  {resolvedSrc && (
    <img
      src={resolvedSrc}
      alt={alt}
      loading={loading}
      decoding="async"
      fetchpriority={fetchPriority}
      sizes={sizes}
      onerror={`this.onerror=null; this.src='${fallback}'; this.classList.add('error');`}
      onload="this.parentElement.querySelector('.skeleton')?.remove(); this.classList.add('loaded');"
      width={width}
      height={height}
      class={`opt-img absolute inset-0 w-full h-full object-cover will-change-transform ${className}`}
    />
  )}
</div>

<style>
  /*
   * CSS animation guarantees the image becomes visible regardless of browser
   * cache state. If the image loads over the network, onload fires and the
   * 'loaded' class snaps it to full opacity instantly. If the image was already
   * cached and onload never fires, the animation completes after 0.4s.
   */
  .opt-img {
    opacity: 0;
    animation: optImgFadeIn 0.4s ease 0.05s forwards;
  }

  .opt-img.loaded {
    animation: none;
    opacity: 1;
  }

  @keyframes optImgFadeIn {
    to { opacity: 1; }
  }

  .skeleton {
    animation: skeletonPulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes skeletonPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.5; }
  }

  .opt-img.error {
    object-fit: contain;
    padding: 1rem;
    background: rgb(30 41 59);
  }
</style>
