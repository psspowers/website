---
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  priority?: boolean;
  aspectRatio?: "16:9" | "4:3" | "1:1";
  sizes?: string;
  fallback?: string;
}

const {
  src,
  alt,
  width,
  height,
  class: className = "",
  priority = false,
  aspectRatio,
  sizes = "(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw",
  fallback = "/pss-logo-black.png",
  preload = false
} = Astro.props;

const imageUrl = new URL(src, Astro.url);

// Preload critical images
if (preload) {
  const link = document.createElement('link');
  link.rel = 'preload';
  link.as = 'image';
  link.href = imageUrl.toString();
  document.head.appendChild(link);
}

// Calculate aspect ratio padding
let paddingBottom = "100%";
if (aspectRatio) {
  const [w, h] = aspectRatio.split(":");
  paddingBottom = `${(Number(h) / Number(w)) * 100}%`;
} else if (width && height) {
  paddingBottom = `${(height / width) * 100}%`;
}

// Determine loading strategy
const loading = priority ? "eager" : "lazy";
const fetchPriority = priority ? "high" : "auto";
---

<div class={`relative overflow-hidden ${className}`} style={`padding-bottom: ${paddingBottom};`}>
  <div class="absolute inset-0 bg-slate-700 animate-pulse skeleton"></div>
  <img
    src={imageUrl}
    alt={alt}
    loading={loading}
    decoding="async"
    fetchpriority={fetchPriority}
    sizes={sizes}
    loading={priority ? "eager" : "lazy"}
    onerror="this.onerror=null; this.src='${fallback}'; this.classList.add('error');"
    width={width}
    height={height}
    class={`absolute inset-0 w-full h-full object-cover will-change-transform ${className}`}
    onload="this.parentElement.querySelector('.skeleton')?.remove();
           this.style.opacity = 1;
           this.style.transform = 'scale(1)';
           this.classList.add('loaded');"
    style="opacity: 0;"
  />
</div>

<style>
  .skeleton {
    @apply bg-slate-700;
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.5;
    }
  }

  img.loaded {
    @apply scale-100 blur-none;
  }
  
  img.error {
    @apply object-contain p-4 bg-slate-800;
  }
</style>