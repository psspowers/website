---
export interface Props {
  name: 'linkedin' | 'check';
  class?: string;
  size?: number;
}

const { name, class: cls = '', size = 20 } = Astro.props;

const icons: Record<Props['name'], { viewBox: string; path: string; attrs?: string }> = {
  linkedin: {
    viewBox: '0 0 24 24',
    path: 'M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z',
  },
  check: {
    viewBox: '0 0 20 20',
    path: 'M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z',
    attrs: 'fill-rule="evenodd" clip-rule="evenodd"',
  },
};

const icon = icons[name];
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={icon.viewBox}
  width={size}
  height={size}
  fill="currentColor"
  class={cls}
  aria-hidden="true"
>
  <path d={icon.path} fill-rule={name === 'check' ? 'evenodd' : undefined} clip-rule={name === 'check' ? 'evenodd' : undefined} />
</svg>
