---
import type { Project } from '../data/projects/types';
import OptimizedImage from './OptimizedImage.astro';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
---

<article
  class="project-card group glass rounded-2xl flex flex-col h-full overflow-hidden hover:bg-slate-800/40 transition-colors"
  data-type={project.type}
  data-status={project.status}
  data-location={project.location}
  data-capacity={project.capacity.toUpperCase()}
  data-aos="fade-up"
  data-aos-delay={index * 50}
>
  <!-- Image Container -->
  <div class="relative aspect-video overflow-hidden rounded-t-2xl bg-slate-800">
    <OptimizedImage
      src={project.image}
      fallback="/pss-logo-black.png"
      alt={project.name}
      aspectRatio="16:9"
      priority={index < 4}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    />

    <div class="absolute inset-0 bg-gradient-to-t from-slate-950/80 via-transparent to-transparent flex flex-col justify-between p-4">
      <div class="flex gap-2">
        <span
          class={`px-2.5 py-0.5 text-xs font-medium rounded-full border ${
            project.status === 'Completed'
              ? 'bg-emerald-500/20 text-emerald-300 border-emerald-500/30'
              : 'bg-blue-500/20 text-blue-300 border-blue-500/30'
          }`}
        >
          {project.status}
        </span>
        <span class="px-2.5 py-0.5 bg-slate-800/80 text-slate-300 text-xs font-medium rounded-full border border-slate-700/50">
          {project.type}
        </span>
      </div>

      <h2 class="text-lg font-bold text-white line-clamp-2">
        {project.name}
      </h2>
    </div>
  </div>

  <!-- Content Container -->
  <div class="p-4 flex flex-col flex-grow">
    <div class="grid grid-cols-2 gap-2 w-full">
      <div class="flex items-baseline justify-between bg-slate-800/60 px-3 py-2 rounded-lg">
        <span class="text-xs text-slate-500 font-medium">Capacity</span>
        <span class="text-sm font-semibold text-emerald-400 ml-2">{project.capacity}</span>
      </div>
      <div class="flex items-baseline justify-between bg-slate-800/60 px-3 py-2 rounded-lg">
        <span class="text-xs text-slate-500 font-medium">COD</span>
        <span class="text-sm font-semibold text-white ml-2">{project.cod}</span>
      </div>
      <div class="flex items-baseline justify-between bg-slate-800/60 px-3 py-2 rounded-lg">
        <span class="text-xs text-slate-500 font-medium">Role</span>
        <span class="text-sm font-semibold text-white ml-2">{project.role}</span>
      </div>
      <div class="flex items-baseline justify-between bg-slate-800/60 px-3 py-2 rounded-lg">
        <span class="text-xs text-slate-500 font-medium">Location</span>
        <span class="text-sm font-semibold text-white ml-2">{project.location}</span>
      </div>
    </div>
  </div>
</article>

<style>
  .project-card {
    opacity: 0;
    animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    height: fit-content;
  }

  .project-card.hidden {
    display: none;
  }

  .project-card:hover .project-card-details {
    transform: translateY(0);
    opacity: 1;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .project-card:hover {
    transform: translateY(-2px);
  }
</style>