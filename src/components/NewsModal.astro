---
import { supabase } from '../lib/supabase';
import { NewsService } from '../services/newsService';

interface PopupRow {
  id: string;
  title: string;
  body: string;
  image_url: string | null;
  cta_label: string;
  cta_url: string;
  delay_seconds: number;
}

// Fetch the most recently created active popup within its date window
const now = new Date().toISOString();
const { data: popupRows } = await supabase
  .from('popup_announcements')
  .select('id, title, body, image_url, cta_label, cta_url, delay_seconds')
  .eq('is_active', true)
  .lte('show_from', now)
  .gte('show_until', now)
  .order('created_at', { ascending: false })
  .limit(1);

const popup = popupRows?.[0] as PopupRow | undefined;

// Fallback: show the latest news item when no popup is configured
let fallbackTitle = '';
let fallbackBody = '';
let fallbackImageUrl: string | null = null;
let fallbackCtaLabel = 'Learn More';
let fallbackCtaUrl = '/news';

if (!popup) {
  try {
    const newsService = NewsService.getInstance();
    const { news } = await newsService.getLatestNews(1);
    const latest = news[0];
    if (latest) {
      fallbackTitle = latest.title;
      fallbackBody = latest.summary.slice(0, 160) + (latest.summary.length > 160 ? '...' : '');
      fallbackImageUrl = latest.image?.url ?? null;
    }
  } catch (_) {
    // no fallback available — render nothing
  }
}

const title = popup?.title ?? fallbackTitle;
const body = popup?.body ?? fallbackBody;
const imageUrl = popup?.image_url ?? fallbackImageUrl;
const ctaLabel = popup?.cta_label ?? fallbackCtaLabel;
const ctaUrl = popup?.cta_url ?? fallbackCtaUrl;
const delayMs = (popup?.delay_seconds ?? 5) * 1000;
const popupId = popup?.id ?? 'news-fallback';

// Nothing to show
const hasContent = title && body;
---

{hasContent && (
<div
  id="news-modal"
  class="fixed inset-0 z-50 hidden px-4 md:px-0"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
  data-popup-id={popupId}
  data-delay={delayMs}
>
  <!-- Backdrop -->
  <div class="fixed inset-0 bg-black bg-opacity-40 backdrop-blur-sm"></div>

  <!-- Modal card -->
  <div class="fixed inset-0 flex items-center justify-center">
    <div
      class="bg-white bg-opacity-95 backdrop-blur-md w-full max-w-[320px] rounded-xl shadow-2xl transform transition-all duration-300 opacity-0 translate-y-4 relative mx-4"
      id="modal-content"
    >
      <!-- Close button -->
      <button
        type="button"
        class="absolute -top-2 -right-2 bg-white w-8 h-8 rounded-full shadow-lg flex items-center justify-center text-gray-500 hover:text-gray-700 focus:outline-none transition-colors duration-200 z-10"
        id="close-modal"
        aria-label="Close"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Content -->
      <div class="p-5">
        {imageUrl && (
          <div class="relative w-full h-[180px] mb-4 rounded-lg overflow-hidden">
            <img
              src={imageUrl}
              alt={title}
              class="w-full h-full object-cover"
              loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
          </div>
        )}

        <h2
          id="modal-title"
          class="font-bold text-lg text-[#1A1A1A] mb-2 leading-tight line-clamp-2"
        >
          {title}
        </h2>

        <p class="text-[#4A4A4A] text-sm leading-relaxed mb-5">
          {body}
        </p>

        <div class="flex flex-col sm:flex-row gap-2">
          <a
            href={ctaUrl}
            class="flex-1 inline-flex justify-center items-center px-4 py-2.5 rounded-lg bg-[#1550b6] text-white font-semibold hover:bg-[#1243a0] transition-all duration-200 text-center text-sm"
          >
            {ctaLabel}
          </a>
          <a
            href="https://www.linkedin.com/company/psspowers"
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 inline-flex justify-center items-center px-3 py-2 rounded-lg bg-[#0077b5] text-white font-semibold hover:bg-[#0077b5]/90 transition-all duration-200 text-center text-xs"
          >
            Follow on LinkedIn
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
)}

<script>
  class NewsModal {
    private modal: HTMLElement | null;
    private content: HTMLElement | null;
    private closeButton: HTMLElement | null;

    constructor() {
      this.modal = document.getElementById('news-modal');
      this.content = document.getElementById('modal-content');
      this.closeButton = document.getElementById('close-modal');

      if (this.modal && this.content && this.closeButton) {
        this.initialize();
      }
    }

    private get sessionKey(): string {
      const id = this.modal?.dataset.popupId ?? 'popup';
      return `popup_shown_${id}`;
    }

    private get delayMs(): number {
      return Number(this.modal?.dataset.delay ?? 5000);
    }

    private initialize = () => {
      if (!sessionStorage.getItem(this.sessionKey)) {
        setTimeout(() => this.showModal(), this.delayMs);
      }
      this.closeButton!.addEventListener('click', this.hideModal);
      this.modal!.addEventListener('click', (e: MouseEvent) => {
        if (e.target === this.modal) this.hideModal();
      });
    }

    private showModal = () => {
      if (sessionStorage.getItem(this.sessionKey) || !this.modal || !this.content) return;
      this.modal.classList.remove('hidden');
      setTimeout(() => {
        this.content!.classList.remove('opacity-0', 'translate-y-4');
        this.content!.classList.add('animate-slideUp');
      }, 50);
      sessionStorage.setItem(this.sessionKey, 'true');
    }

    private hideModal = () => {
      if (!this.modal || !this.content) return;
      this.content.classList.add('opacity-0', 'translate-y-4', 'animate-slideDown');
      setTimeout(() => {
        this.modal!.classList.add('hidden');
        this.content!.classList.remove('animate-slideDown');
      }, 300);
    }
  }

  document.addEventListener('DOMContentLoaded', () => { new NewsModal(); });
</script>

<style>
  @keyframes slideUp {
    from { transform: translateY(1rem); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }
  @keyframes slideDown {
    from { transform: translateY(0);    opacity: 1; }
    to   { transform: translateY(1rem); opacity: 0; }
  }
  .animate-slideUp  { animation: slideUp  0.3s ease-out forwards; }
  .animate-slideDown { animation: slideDown 0.3s ease-out forwards; }
</style>
