---
import { supabase } from '../lib/supabase';
import Icon from './Icon.astro';
import BrandName from './BrandName.astro';
import { detectOffice } from '../utils/geoOffice';

const currentYear = new Date().getFullYear();

interface OfficeRow {
  country: string;
  name: string;
  address: string;
  phone: string | null;
  email: string | null;
  show_in_list: boolean;
  country_code: string | null;
}

const { data: officeRows } = await supabase
  .from('offices')
  .select('country, name, address, phone, email, show_in_list, country_code')
  .order('created_at', { ascending: true });

const offices = (officeRows ?? []) as OfficeRow[];

const allOfficesMapped = offices.map(o => ({
  country: o.country,
  name: o.name,
  address: o.address,
  phone: o.phone ?? undefined,
  email: o.email ?? undefined,
  coordinates: [0, 0] as [number, number],
  showInList: o.show_in_list,
  countryCode: o.country_code ?? undefined,
}));

const contactOffice = detectOffice(Astro.request.headers, allOfficesMapped);
const isHQ = contactOffice === allOfficesMapped[0] || contactOffice.country === allOfficesMapped[0]?.country;
const otherOffices = offices.filter(o => o.show_in_list && o.name !== contactOffice.name);
---

<footer class="bg-slate-900 border-t border-slate-800 py-12">
  <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-10">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center mb-4" style="min-height: auto;">
          <img src="/Pss.O_Logo_Cropped.png" alt="PssO" class="h-8 w-auto object-contain" />
        </a>
        <p class="text-slate-400 text-sm leading-relaxed">
          Leading the transition to bankable renewable energy across Asia since 2012.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Quick Links</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/about" class="text-slate-400 hover:text-emerald-400 transition-colors" style="min-height: auto;">About Us</a></li>
          <li><a href="/people" class="text-slate-400 hover:text-emerald-400 transition-colors" style="min-height: auto;">Our Team</a></li>
          <li><a href="/services" class="text-slate-400 hover:text-emerald-400 transition-colors" style="min-height: auto;">Services</a></li>
          <li><a href="/projects" class="text-slate-400 hover:text-emerald-400 transition-colors" style="min-height: auto;">Projects</a></li>
          <li><a href="/news" class="text-slate-400 hover:text-emerald-400 transition-colors" style="min-height: auto;">News</a></li>
          <li><a href="/group" class="text-slate-400 hover:text-emerald-400 transition-colors" style="min-height: auto;">Group</a></li>
          <li><a href="/contact" class="text-slate-400 hover:text-emerald-400 transition-colors" style="min-height: auto;">Contact</a></li>
        </ul>
      </div>

      <!-- Contact (geo-localised) -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Contact</h4>
        {contactOffice ? (
          <ul class="space-y-3 text-sm text-slate-400">
            <li>
              <span class="text-slate-300 font-medium block">
                {contactOffice.country}{isHQ ? ' (HQ)' : ` — ${contactOffice.name}`}
              </span>
              {contactOffice.address}
            </li>
            {contactOffice.phone && (
              <li class="pt-1">
                <a href={`tel:${contactOffice.phone.replace(/\s+/g, '')}`} class="hover:text-emerald-400 transition-colors" style="min-height: auto;">{contactOffice.phone}</a>
              </li>
            )}
            {contactOffice.email && (
              <li>
                <a href={`mailto:${contactOffice.email}`} class="hover:text-emerald-400 transition-colors" style="min-height: auto;">{contactOffice.email}</a>
              </li>
            )}
          </ul>
        ) : (
          <p class="text-slate-500 text-sm">No offices configured.</p>
        )}
      </div>

      <!-- Other Offices & Social -->
      <div>
        {otherOffices.length > 0 && (
          <>
            <h4 class="text-white font-semibold text-sm mb-4">Other Offices</h4>
            <ul class="space-y-2 text-sm text-slate-400 mb-6">
              {otherOffices.map(o => (
                <li>
                  <span class="text-slate-300 font-medium">{o.country}</span>
                  {o.address ? <> &mdash; {o.address}</> : ''}
                </li>
              ))}
            </ul>
          </>
        )}
        <a
          href="https://www.linkedin.com/company/pssorange/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-x-2 text-slate-400 hover:text-emerald-400 transition-colors text-sm"
          style="min-height: auto;"
        >
          <Icon name="linkedin" size={20} class="w-5 h-5" />
          LinkedIn
        </a>
      </div>
    </div>

    <div class="border-t border-slate-800 pt-6 flex flex-col md:flex-row items-center justify-between gap-y-3 text-xs text-slate-500">
      <span>&copy; {currentYear} <BrandName />. All rights reserved. Power Systems &amp; Solutions Co., Ltd.</span>
      <div class="flex gap-x-6">
        <a href="/privacy" class="hover:text-slate-300 transition-colors" style="min-height: auto;">Privacy</a>
        <a href="/legal" class="hover:text-slate-300 transition-colors" style="min-height: auto;">Legal</a>
      </div>
    </div>
  </div>
</footer>
