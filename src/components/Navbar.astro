---
const navLinks = [
  { href: "#about", label: "About" },
  { href: "#portfolio", label: "Portfolio" },
  { href: "#impact", label: "Impact" },
  { href: "#innovation", label: "Innovation" },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-slate-950/95 backdrop-blur-lg border-b border-slate-800 transition-all">
  <div class="max-w-screen-2xl mx-auto px-8">
    <div class="flex items-center justify-between h-20">
      
      <!-- Logo -->
      <a href="/" class="flex items-center gap-x-3 group">
        <div class="w-9 h-9 bg-emerald-500 rounded-2xl flex items-center justify-center">
          <span class="text-slate-950 text-2xl font-bold">P</span>
        </div>
        <div class="flex items-baseline">
          <span class="font-semibold text-3xl tracking-tighter">PSS</span>
          <span class="font-semibold text-3xl tracking-tighter text-emerald-400">Powers</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-x-9 text-sm font-medium">
        {navLinks.map(link => (
          <a href={link.href} class="text-slate-300 hover:text-white transition-colors">
            {link.label}
          </a>
        ))}
      </div>

      <!-- CTA Buttons -->
      <div class="hidden md:flex items-center gap-x-4">
        <a 
          href="#contact" 
          class="px-6 py-2.5 text-sm font-semibold rounded-3xl border border-slate-700 hover:bg-slate-900 transition-colors"
        >
          Contact Us
        </a>
        <a 
          href="#contact" 
          class="px-6 py-2.5 bg-emerald-500 hover:bg-emerald-600 transition-all text-slate-950 font-semibold text-sm rounded-3xl flex items-center gap-x-2"
        >
          Partner With Us
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button 
        id="mobile-menu-btn"
        class="md:hidden w-10 h-10 flex items-center justify-center text-slate-300 hover:text-white"
        aria-label="Toggle menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-800 bg-slate-950">
    <div class="px-8 py-6 flex flex-col gap-y-4 text-sm font-medium">
      {navLinks.map(link => (
        <a href={link.href} class="text-slate-300 hover:text-white py-1 transition-colors">
          {link.label}
        </a>
      ))}
      <div class="pt-4 border-t border-slate-800 flex flex-col gap-y-3">
        <a href="#contact" class="px-6 py-3 text-center border border-slate-700 rounded-3xl">Contact Us</a>
        <a href="#contact" class="px-6 py-3 text-center bg-emerald-500 text-slate-950 font-semibold rounded-3xl">Partner With Us</a>
      </div>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>