---
const currentPath = Astro.url.pathname;

const links = [
  { text: 'Home', href: '/' },
  { text: 'About', href: '/about' },
  { text: 'Services', href: '/services' },
  { text: 'Solar Savings', href: '/solar-savings' },
  { text: 'Projects', href: '/projects' },
  { text: 'News', href: '/news' },
  { text: 'Group', href: '/group' },
];
---

<header class="fixed w-full z-50 transition-all duration-300 bg-slate-950/70 backdrop-blur-md border-b border-white/5" id="main-nav">
  <nav class="max-w-screen-2xl mx-auto px-6 lg:px-8 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center flex-shrink-0" style="min-height: auto;">
      <img src="/Pss.O_Logo_Cropped.png" alt="PssO" class="h-10 w-auto object-contain" />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-x-5">
      {links.map(link => (
        <a
          href={link.href}
          style="min-height: auto;"
          class={`text-sm font-medium tracking-normal transition-colors duration-200 ${
            (currentPath === link.href) || (currentPath.startsWith(link.href) && link.href !== '/')
              ? 'text-emerald-400 font-semibold'
              : 'text-slate-300 hover:text-white'
          }`}
        >
          {link.text}
        </a>
      ))}
    </div>

    <!-- CTA Buttons -->
    <div class="flex items-center gap-x-3">
      <a
        href="/partner-with-us"
        class="hidden md:inline-flex items-center px-5 py-2 bg-[#059669] hover:bg-[#047857] transition-colors text-white font-semibold text-sm rounded-full"
        style="min-height: auto;"
      >
        Partner With Us
      </a>
      <!-- Mobile toggle — 44x44px minimum for Apple HIG compliance, touch-action removes 300ms iOS tap delay -->
      <button
        class="md:hidden flex items-center justify-center text-slate-300 hover:text-white active:text-white transition-colors rounded-lg"
        id="mobile-menu-button"
        aria-label="Toggle menu"
        aria-expanded="false"
        style="width: 44px; height: 44px; touch-action: manipulation;"
      >
        <svg id="menu-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div class="md:hidden hidden glass border-t border-slate-800" id="mobile-menu">
    <div class="max-w-screen-2xl mx-auto px-6 py-4 flex flex-col gap-y-1">
      {links.map(link => (
        <a
          href={link.href}
          class={`mobile-nav-link py-3 text-base font-medium transition-colors border-b border-slate-800/60 last:border-0 ${
            (currentPath === link.href) || (currentPath.startsWith(link.href) && link.href !== '/')
              ? 'text-emerald-400'
              : 'text-slate-300 active:text-white'
          }`}
          style="min-height: 48px; display: flex; align-items: center; touch-action: manipulation;"
        >
          {link.text}
        </a>
      ))}
      <a
        href="/partner-with-us"
        class="mobile-nav-link py-3 text-base font-medium text-emerald-400 hover:text-emerald-300 active:text-emerald-200 transition-colors"
        style="min-height: 48px; display: flex; align-items: center; touch-action: manipulation;"
      >
        Partner With Us
      </a>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('main-nav');
  const btn = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  function updateNavBackground() {
    const isHome = window.location.pathname === '/';
    if (window.scrollY > 60 || !isHome) {
      nav?.classList.add('nav-scrolled');
    } else {
      nav?.classList.remove('nav-scrolled');
    }
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    menuIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
  }

  window.addEventListener('scroll', updateNavBackground, { passive: true });
  updateNavBackground();

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    const isNowOpen = !menu?.classList.contains('hidden');
    menuIcon?.classList.toggle('hidden', isNowOpen);
    closeIcon?.classList.toggle('hidden', !isNowOpen);
    btn.setAttribute('aria-expanded', String(isNowOpen));
  });

  // Close menu when any nav link is tapped so users get immediate feedback
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
