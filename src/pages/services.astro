---
import Layout from '../layouts/Layout.astro';
import AnimatedStats from '../components/AnimatedStats.astro';
import { supabase } from '../lib/supabase';

interface Service {
  id: string;
  title: string;
  description: string;
  icon_path: string;
  features: string[];
  stat_value: number;
  stat_label: string;
  stat_format: string;
  success_client: string;
  success_result: string;
  display_order: number;
}

const { data } = await supabase
  .from('services')
  .select('*')
  .order('display_order', { ascending: true });

const services: Service[] = (data as Service[]) ?? [];
---

<Layout
  title="Services - PSS Powers"
  description="Comprehensive renewable energy solutions including solar, wind, BESS, and energy storage services. From development and financing to operations and maintenance."
  type="website"
>
  <main class="pt-20">
    <!-- Hero -->
    <section class="dark-gradient-header">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="max-w-3xl text-white" data-aos="fade-up">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-4">What We Offer</p>
          <h1 class="font-display text-4xl md:text-5xl font-bold tracking-tight mb-6">
            Comprehensive Power Solutions
          </h1>
          <p class="text-xl text-slate-300 leading-relaxed">
            From system design to ongoing maintenance, we deliver end-to-end power solutions
            that drive efficiency and reliability.
          </p>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-8">
          {services.map((service, index) => (
            <div class="glass rounded-2xl overflow-hidden" data-aos="fade-up" data-aos-delay={index * 100}>
              <div class="p-8">
                <div class="w-12 h-12 rounded-2xl bg-emerald-500/10 flex items-center justify-center mb-6">
                  <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={service.icon_path} />
                  </svg>
                </div>
                <h2 class="font-display text-2xl font-bold text-white mb-4">{service.title}</h2>
                <p class="text-slate-400 mb-6 leading-relaxed">{service.description}</p>

                <div class="mb-6">
                  <h3 class="text-white font-semibold text-sm mb-3">Key Features</h3>
                  <ul class="space-y-2">
                    {service.features.map(feature => (
                      <li class="flex items-center gap-x-2.5 text-slate-400 text-sm">
                        <svg class="w-4 h-4 text-emerald-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                        {feature}
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="flex items-center justify-center mb-6">
                  <AnimatedStats
                    value={service.stat_value}
                    label={service.stat_label}
                    format={service.stat_format}
                  />
                </div>

                <div class="border-t border-slate-700/50 pt-6">
                  <h3 class="text-white font-semibold text-sm mb-3">Success Story</h3>
                  <div class="bg-slate-800/60 p-4 rounded-xl">
                    <p class="text-white font-medium text-sm mb-1">{service.success_client}</p>
                    <p class="text-slate-400 text-sm">{service.success_result}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="py-20 solar-gradient">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12" data-aos="fade-up">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-white tracking-tight mb-4">Ready to Get Started?</h2>
            <p class="text-slate-300 text-lg">Contact our team for expert consultation and support.</p>
          </div>

          <div class="grid md:grid-cols-2 gap-8">
            <div data-aos="fade-up">
              <h3 class="text-white font-bold text-xl mb-4">Quick Contact</h3>
              <div class="space-y-4">
                <a href="mailto:info@psspowers.com" class="flex items-center gap-x-3 text-slate-300 hover:text-emerald-400 transition-colors" style="min-height: auto;">
                  <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                    <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                  </svg>
                  info@psspowers.com
                </a>
                <div class="flex items-center gap-x-3 text-slate-300">
                  <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                  </svg>
                  +66 2 106 2611
                </div>
              </div>
            </div>

            <div data-aos="fade-up" data-aos-delay="100">
              <form class="space-y-4 glass rounded-2xl p-6">
                <div>
                  <label class="block text-sm font-medium text-slate-300 mb-1.5">Name</label>
                  <input type="text" class="w-full px-4 py-3 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all text-sm" placeholder="Your name" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-slate-300 mb-1.5">Email</label>
                  <input type="email" class="w-full px-4 py-3 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all text-sm" placeholder="your@email.com" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-slate-300 mb-1.5">Message</label>
                  <textarea class="w-full px-4 py-3 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all resize-none text-sm" rows="4" placeholder="How can we help you?"></textarea>
                </div>
                <a href="/contact" class="block w-full text-center px-8 py-4 bg-emerald-500 hover:bg-emerald-600 text-slate-950 font-semibold rounded-full transition-colors text-sm" style="min-height: auto;">
                  Send Message
                </a>
              </form>
              <p class="text-slate-500 text-xs mt-3">* We typically respond within 24 hours</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
