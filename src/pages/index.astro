<script>
  // ── Project filter tabs ───────────────────────────────────────
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('#project-filters button');
  const projectItems = document.querySelectorAll<HTMLElement>('.project-item');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      filterBtns.forEach(b => {
        b.classList.remove('bg-emerald-500', 'border-emerald-500', 'text-slate-950');
        b.classList.add('glass', 'border-slate-700', 'text-slate-400');
      });
      btn.classList.add('bg-emerald-500', 'border-emerald-500', 'text-slate-950');
      btn.classList.remove('glass', 'border-slate-700', 'text-slate-400');

      projectItems.forEach(item => {
        if (filter === 'All' || item.dataset.type === filter) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });

  // ── Project modal ─────────────────────────────────────────────
  const modal = document.getElementById('project-modal');
  const backdrop = document.getElementById('modal-backdrop');
  const closeBtn = document.getElementById('modal-close');

  function openModal(data: any) {
    if (!modal) return;
    (document.getElementById('modal-img') as HTMLImageElement).src = data.image;
    (document.getElementById('modal-img') as HTMLImageElement).alt = data.name;
    document.getElementById('modal-type')!.textContent = data.type;
    document.getElementById('modal-country')!.textContent = data.country;
    document.getElementById('modal-year')!.textContent = data.year;
    document.getElementById('modal-name')!.textContent = data.name;
    document.getElementById('modal-capacity')!.textContent = data.capacity + ' MW';
    document.getElementById('modal-desc')!.textContent = data.description;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  projectItems.forEach(item => {
    item.addEventListener('click', () => {
      try {
        const data = JSON.parse(item.dataset.project || '{}');
        openModal(data);
      } catch (_) {}
    });
  });

  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  // ── Solar Savings Calculator ──────────────────────────────────
  const slider = document.getElementById('energy-slider') as HTMLInputElement;
  const sliderValue = document.getElementById('slider-value');
  const calcGen = document.getElementById('calc-gen');
  const calcSavings = document.getElementById('calc-savings');
  const calcPayback = document.getElementById('calc-payback');

  function updateCalculator() {
    const consumption = parseInt(slider.value);
    const coverage = 0.725; // 72.5% coverage ratio
    const generation = Math.round(consumption * coverage);
    const tariff = 0.09; // USD per kWh
    const annualSavings = generation * tariff;
    const systemSizeKwp = generation / 1450; // peak sun hours
    const installCost = systemSizeKwp * 750; // USD 0.75/Wp
    const payback = installCost / annualSavings;

    if (sliderValue) sliderValue.textContent = consumption.toLocaleString();
    if (calcGen) calcGen.textContent = generation.toLocaleString() + ' kWh';
    if (calcSavings) calcSavings.textContent = '$' + Math.round(annualSavings).toLocaleString();
    if (calcPayback) calcPayback.textContent = payback.toFixed(1) + ' yrs';
  }

  slider?.addEventListener('input', updateCalculator);
  updateCalculator();
</script>
