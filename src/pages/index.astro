---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout 
  title="PSS Powers | Powering Asia's Sustainable Future"
  description="Bankable renewable energy development, EPC excellence, and long-term O&M across Thailand, India, and Southeast Asia."
>
  <Navbar />

  <!-- HERO SECTION -->
  <section class="relative min-h-[100dvh] flex items-center pt-16 bg-slate-950 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(#334155_0.8px,transparent_1px)] bg-[length:4px_4px] opacity-40"></div>
    
    <div class="max-w-screen-2xl mx-auto px-8 relative z-10 pt-12 pb-20">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-x-2 px-4 py-1.5 rounded-3xl bg-white/10 backdrop-blur-md border border-white/20 mb-6">
          <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
          <span class="text-sm font-medium tracking-wide">I Squared Capital Partnership • 300 MW Thailand Pipeline</span>
        </div>
        
        <h1 class="font-display text-7xl md:text-8xl leading-[0.92] tracking-tighter font-bold mb-6 text-white">
          Powering Asia's<br>clean energy future.
        </h1>
        
        <p class="max-w-lg text-2xl text-slate-300 mb-10">
          Expert renewable energy development, EPC excellence, and long-term O&amp;M across Thailand, India &amp; Southeast Asia.
        </p>
        
        <div class="flex flex-wrap items-center gap-4">
          <a href="#portfolio" class="group inline-flex items-center justify-center gap-x-3 px-9 py-4 bg-white text-slate-950 font-semibold rounded-3xl text-lg hover:bg-emerald-50 transition-all">
            Explore Projects
            <span class="group-hover:translate-x-1 transition">→</span>
          </a>
          <a href="#contact" class="inline-flex items-center justify-center gap-x-3 px-8 py-4 border border-white/30 hover:bg-white/10 transition-all rounded-3xl text-lg font-medium text-white">
            Schedule a Discussion
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST / KEY STATS -->
  <div class="max-w-screen-2xl mx-auto px-8 -mt-10 relative z-20">
    <div class="glass rounded-3xl p-8 md:p-10 grid grid-cols-2 md:grid-cols-4 gap-y-8 border border-slate-800">
      <div class="text-center">
        <div class="text-emerald-400 text-sm font-semibold tracking-widest mb-1">PIPELINE</div>
        <div class="stat-value text-6xl font-bold text-white">450</div>
        <div class="text-slate-400 text-sm mt-1">MW+ Total Pipeline</div>
      </div>
      <div class="text-center">
        <div class="text-emerald-400 text-sm font-semibold tracking-widest mb-1">OPERATIONAL</div>
        <div class="stat-value text-6xl font-bold text-white">145</div>
        <div class="text-slate-400 text-sm mt-1">MW Operational Capacity</div>
      </div>
      <div class="text-center">
        <div class="text-emerald-400 text-sm font-semibold tracking-widest mb-1">DELIVERED</div>
        <div class="stat-value text-6xl font-bold text-white">100</div>
        <div class="text-slate-400 text-sm mt-1">Projects Completed</div>
      </div>
      <div class="text-center">
        <div class="text-emerald-400 text-sm font-semibold tracking-widest mb-1">IMPACT</div>
        <div class="stat-value text-6xl font-bold text-white">138k</div>
        <div class="text-slate-400 text-sm mt-1">Tonnes CO₂ Avoided / Year</div>
      </div>
    </div>
  </div>

  <!-- SERVICES / EXPERTISE -->
  <section class="max-w-screen-2xl mx-auto px-8 pt-20 pb-16">
    <div class="text-center mb-12">
      <div class="text-emerald-400 text-sm tracking-[3px] font-semibold mb-2">WHAT WE DELIVER</div>
      <h2 class="font-display text-5xl tracking-tighter">End-to-end renewable energy expertise</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="glass p-8 rounded-3xl border border-slate-800">
        <div class="w-12 h-12 bg-emerald-500/10 rounded-2xl flex items-center justify-center mb-6 text-emerald-400">
          <span class="text-3xl">📍</span>
        </div>
        <h3 class="font-semibold text-2xl mb-3">Project Development</h3>
        <p class="text-slate-400">Site identification, feasibility, permitting, offtake agreements, and project financing support.</p>
      </div>

      <div class="glass p-8 rounded-3xl border border-slate-800">
        <div class="w-12 h-12 bg-emerald-500/10 rounded-2xl flex items-center justify-center mb-6 text-emerald-400">
          <span class="text-3xl">🏗️</span>
        </div>
        <h3 class="font-semibold text-2xl mb-3">EPC Excellence</h3>
        <p class="text-slate-400">In-house engineering, procurement, and construction with proven track record across rooftop, ground-mount, and floating solar.</p>
      </div>

      <div class="glass p-8 rounded-3xl border border-slate-800">
        <div class="w-12 h-12 bg-emerald-500/10 rounded-2xl flex items-center justify-center mb-6 text-emerald-400">
          <span class="text-3xl">⚙️</span>
        </div>
        <h3 class="font-semibold text-2xl mb-3">O&M & Asset Management</h3>
        <p class="text-slate-400">Long-term performance optimization and predictive maintenance to maximize yield over 25+ years.</p>
      </div>
    </div>
  </section>

  <!-- PORTFOLIO TEASER -->
  <section id="portfolio" class="bg-slate-900 py-16">
    <div class="max-w-screen-2xl mx-auto px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-y-4 mb-10">
        <div>
          <div class="text-emerald-400 text-sm tracking-[3px] font-semibold">OUR WORK</div>
          <h2 class="font-display text-5xl tracking-tighter">Featured Projects</h2>
        </div>
        <a href="#contact" class="text-emerald-400 hover:text-emerald-300 flex items-center gap-x-2 group">
          View full portfolio 
          <span class="group-hover:translate-x-1 transition">→</span>
        </a>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Placeholder project cards - we will make these dynamic later -->
        <div class="glass rounded-3xl overflow-hidden border border-slate-800">
          <div class="h-48 bg-slate-800 flex items-center justify-center text-slate-500">Project Image</div>
          <div class="p-6">
            <div class="font-semibold text-xl">Vardhaman Steel - 60 MW</div>
            <div class="text-sm text-slate-400">Punjab, India • Ground Mount • In Progress</div>
          </div>
        </div>

        <div class="glass rounded-3xl overflow-hidden border border-slate-800">
          <div class="h-48 bg-slate-800 flex items-center justify-center text-slate-500">Project Image</div>
          <div class="p-6">
            <div class="font-semibold text-xl">IRPC Floating Solar - 12 MW</div>
            <div class="text-sm text-slate-400">Rayong, Thailand • Floating • Completed</div>
          </div>
        </div>

        <div class="glass rounded-3xl overflow-hidden border border-slate-800">
          <div class="h-48 bg-slate-800 flex items-center justify-center text-slate-500">Project Image</div>
          <div class="p-6">
            <div class="font-semibold text-xl">Khon Kaen University - 30 MW</div>
            <div class="text-sm text-slate-400">Khon Kaen, Thailand • Ground Mount • In Progress</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section id="contact" class="max-w-screen-2xl mx-auto px-8 py-20">
    <div class="glass rounded-[3rem] px-10 md:px-16 py-16 border border-slate-700 text-center">
      <h2 class="font-display text-5xl tracking-tighter mb-4">Ready to power your next project?</h2>
      <p class="max-w-md mx-auto text-lg text-slate-300 mb-8">
        Whether you're developing a large-scale solar asset or seeking a reliable long-term O&M partner — let's talk.
      </p>
      <a href="mailto:info@psspowers.com" class="btn btn-primary text-lg px-10 py-4">
        Contact Our Team
      </a>
    </div>
  </section>
</Layout>