---
import Layout from '../layouts/Layout.astro';
import SolarCalculator from '../components/SolarCalculator.astro';
import FeaturedProjects from '../components/FeaturedProjects.astro';
import PartnershipCircles from '../components/PartnershipCircles.astro';
import { supabase } from '../lib/supabase';
import { fetchFeaturedProjects, fetchAllProjectsForMetrics } from '../services/projectsDbService';
import { fetchOffices } from '../services/officesDbService';
import { detectOffice } from '../utils/geoOffice';

const results = await Promise.allSettled([
  supabase.from('about_stats').select('*').order('display_order', { ascending: true }),
  supabase.from('milestones').select('*').order('display_order', { ascending: true }),
  supabase.from('site_settings').select('key,value'),
  fetchFeaturedProjects(),
  fetchAllProjectsForMetrics(),
]);

const { data: dbStats }      = results[0].status === 'fulfilled' ? results[0].value : { data: null };
const { data: dbMilestones } = results[1].status === 'fulfilled' ? results[1].value : { data: null };
const { data: dbSettings }   = results[2].status === 'fulfilled' ? results[2].value : { data: null };
const featuredProjects       = results[3].status === 'fulfilled' ? results[3].value : [];
const allProjectMetrics      = results[4].status === 'fulfilled' ? results[4].value : [];

const heroStats = (dbStats ?? []) as { value: number; label: string; format: string }[];
const milestones = (dbMilestones ?? []) as { year: string; event: string; logo_url: string | null }[];

const settingsMap: Record<string, string> = {};
(dbSettings ?? []).forEach((row: { key: string; value: string }) => { settingsMap[row.key] = row.value; });

const heroBadgeText = settingsMap['hero_badge_text'] ?? 'Now active across 6 countries in Asia';
const heroParagraph = settingsMap['hero_paragraph'] ?? 'Pss.Orange delivers bankable renewable energy solutions across Asia — from initial development and financing through to EPC execution, O&M, and repowering. 450+ MW installed since 2015.';

const employeesStat = heroStats.find(s =>
  s.label.toLowerCase().includes('employee') || s.label.toLowerCase().includes('team')
);
const heroTeamCount = employeesStat
  ? `${employeesStat.value.toLocaleString()}${employeesStat.format ?? ''}`
  : (settingsMap['hero_team_count'] ?? '50+');

function parseCapacityMW(capacity: string): number {
  const m = capacity.match(/[\d.]+/);
  return m ? parseFloat(m[0]) : 0;
}

const totalCapacityMW = allProjectMetrics.reduce((sum, p) => sum + parseCapacityMW(p.capacity), 0);
const cleanEnergyGWh = Math.round(totalCapacityMW * 488 / 1000);

const offices = await fetchOffices();
const geoOffice = detectOffice(Astro.request.headers, offices);
const isHQ = offices.length === 0 || geoOffice === offices[0];
const ctaPhone = geoOffice.phone;
const ctaEmail = geoOffice.email ?? 'info@pssorange.com';
const ctaLabel = isHQ
  ? `${geoOffice.country} (HQ)`
  : `${geoOffice.name}, ${geoOffice.country}`;
const co2AvoidedTonnes = Math.round(totalCapacityMW * 488 * 0.63 / 1000);
const co2Label = co2AvoidedTonnes >= 1000 ? `${Math.round(co2AvoidedTonnes / 1000 * 10) / 10}k` : String(co2AvoidedTonnes);

const filterTypes = ['All', ...Array.from(new Set(featuredProjects.map(p => p.type)))];
---

<Layout
  title="Pss.Orange — Bankable Renewable Energy Across Asia"
  description="Leading the transition to bankable renewable energy across Asia since 2015. Over 450 MW installed, serving industrial and utility clients in Thailand, India, and Singapore."
>
  <main>
    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="relative min-h-screen flex flex-col bg-cover bg-center bg-no-repeat overflow-hidden" style="background-image: url('/Final_Hero_shot_website.jpg');">
      <div class="absolute inset-0 bg-gradient-to-r from-slate-950/90 via-slate-950/65 to-slate-950/25 sm:from-slate-950/85"></div>

      <div class="relative flex-1 flex items-center w-full max-w-screen-2xl mx-auto px-6 lg:px-8 pt-32 pb-8">
        <div>
          <div class="inline-flex items-center gap-x-2 px-3.5 py-1.5 rounded-full glass text-sm text-emerald-300 font-medium mb-8" data-aos="fade-down">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            {heroBadgeText}
          </div>

          <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-bold text-white leading-[1.05] tracking-[-0.03em] max-w-4xl mb-8" data-aos="fade-up" data-aos-delay="50">
            Cheaper. Cleaner.<br />
            <span class="text-emerald-400">Predictable Energy</span><br />
            Across Asia
          </h1>

          <p class="text-xl text-slate-300 max-w-2xl mb-10 leading-relaxed" data-aos="fade-up" data-aos-delay="100">
            {heroParagraph}
          </p>

          <div class="flex flex-wrap gap-4 mb-12" data-aos="fade-up" data-aos-delay="150">
            <a href="/projects" class="inline-flex items-center gap-x-2 px-7 py-3.5 bg-emerald-500 hover:bg-emerald-600 transition-colors text-slate-950 font-semibold rounded-full text-sm" style="min-height: auto;">
              Explore Projects
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
            <a href="/partner-with-us" class="inline-flex items-center gap-x-2 px-7 py-3.5 glass hover:bg-slate-700/50 transition-colors text-slate-200 font-semibold rounded-full text-sm" style="min-height: auto;">
              Partner With Us
            </a>
          </div>

          <div class="flex items-center gap-x-4" data-aos="fade-up" data-aos-delay="200">
            <div class="flex -space-x-2.5">
              <img src="/Team/Nakkarin.jpg" alt="Nakkarin" class="w-10 h-10 rounded-full border-2 border-slate-800 object-cover" onerror="this.style.display='none'" />
              <img src="/Team/Sam.jpg" alt="Sam Yamdagni" class="w-10 h-10 rounded-full border-2 border-slate-800 object-cover" onerror="this.style.display='none'" />
              <img src="/Team/Suraphol.jpg" alt="Suraphol" class="w-10 h-10 rounded-full border-2 border-slate-800 object-cover" onerror="this.style.display='none'" />
              <div class="w-10 h-10 rounded-full border-2 border-slate-800 bg-slate-700 flex items-center justify-center text-xs font-semibold text-slate-300">+5</div>
            </div>
            <p class="text-slate-400 text-sm">{heroTeamCount} energy professionals across Asia</p>
          </div>
        </div>
      </div>

      <!-- Stats anchored at the bottom of the hero — visible above the fold -->
      <div class="relative w-full max-w-screen-2xl mx-auto px-6 lg:px-8 pb-12" data-aos="fade-up" data-aos-delay="250">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {heroStats.map(stat => (
            <div class="glass rounded-2xl p-5 text-center">
              <p class="font-display text-3xl md:text-4xl font-bold text-white mb-1">
                {stat.value}<span class="text-emerald-400">{stat.format}</span>
              </p>
              <p class="text-slate-400 text-sm">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── I Squared Capital ─────────────────────────────────── -->
    <section class="py-20 border-b border-slate-800/60">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div data-aos="fade-right">
            <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-4">Institutional Partnership</p>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-white tracking-tight mb-5 leading-tight">
              Backed by one of the world's largest infrastructure investors
            </h2>
            <p class="text-slate-400 leading-relaxed mb-4">
              PSS Orange is backed by I Squared Capital — a leading global infrastructure investor with $40B+ in assets under management — and partners with Berde, their renewable energy subsidiary.
            </p>
            <p class="text-slate-400 leading-relaxed mb-8">
              This institutional backing means every project we deliver meets the highest standards of financial governance, technical execution, and long-term operational accountability. It also means we can mobilise significant capital for the right opportunities.
            </p>
            <div class="flex flex-wrap gap-4">
              <a
                href="/partner-with-us#investment-capital-partner"
                class="inline-flex items-center gap-x-2 px-6 py-3 bg-emerald-500 hover:bg-emerald-600 transition-colors text-slate-950 font-semibold rounded-full text-sm"
                style="min-height: auto;"
              >
                Partner &amp; Grow with Us
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
              <a
                href="/news"
                class="inline-flex items-center gap-x-2 px-6 py-3 border border-slate-600 hover:border-slate-400 text-slate-300 hover:text-white transition-colors rounded-full text-sm font-semibold"
                style="min-height: auto;"
              >
                Read announcement
              </a>
            </div>
          </div>

          <div class="flex flex-col gap-6" data-aos="fade-left">
            <div class="glass rounded-2xl overflow-hidden">
              <img
                src="/News_Images/2025-02_2025-02-15_isq-partnership-announcement.jpg"
                alt="I Squared Capital Partnership Announcement"
                class="w-full object-cover aspect-video"
              />
              <div class="p-6 flex items-center gap-4">
                <div class="bg-[#0B1F3F] rounded-xl px-5 py-3 flex-shrink-0">
                  <p class="text-white text-[10px] uppercase tracking-wider font-semibold mb-1">Financial Partner</p>
                  <div class="bg-white rounded-lg p-2 mt-1">
                    <img
                      src="/i-squared-capital-logo.png"
                      alt="I Squared Capital"
                      class="h-6 w-auto object-contain"
                    />
                  </div>
                </div>
                <div>
                  <p class="text-white font-semibold text-sm">Strategic Partnership Announced</p>
                  <p class="text-slate-400 text-xs mt-0.5">February 2025 — Scaling renewable energy across Asia</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── About / Mission ───────────────────────────────────── -->
    <section class="py-28 max-w-screen-2xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div data-aos="fade-right">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-4">Our Mission</p>
          <h2 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight tracking-tight mb-6">
            Making clean energy<br />bankable across Asia
          </h2>
          <p class="text-slate-400 text-lg leading-relaxed mb-6">
            Founded in Bangkok in 2012, Pss.Orange bridges the gap between ambitious
            renewable energy targets and the rigorous financial standards demanded by
            institutional investors. We combine deep local market knowledge with
            international project finance expertise.
          </p>
          <p class="text-slate-400 text-lg leading-relaxed mb-8">
            Our team of 50+ engineers, financiers, and project managers operates across
            Thailand, India, Singapore, Vietnam, the Philippines, and Japan — delivering
            technically excellent, commercially bankable projects at every scale.
          </p>
          <a href="/about" class="inline-flex items-center gap-x-2 text-emerald-400 font-semibold hover:text-emerald-300 transition-colors" style="min-height: auto;">
            Learn about our team
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

        <div class="glass rounded-3xl p-8" data-aos="fade-left">
          <h3 class="text-white font-semibold text-lg mb-6">Core Capabilities</h3>
          <div class="space-y-5">
            {[
              { icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7', label: 'Development & Financing', desc: 'Full project lifecycle from site selection to financial close' },
              { icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4', label: 'Turnkey EPC', desc: 'End-to-end engineering, procurement, and construction' },
              { icon: 'M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4', label: 'O&M Services', desc: '24/7 monitoring with 99.9% system availability target' },
              { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', label: 'Retrofit & Repowering', desc: 'Modernisation services delivering 25%+ efficiency gains' },
            ].map(item => (
              <div class="flex gap-x-4 p-4 rounded-xl hover:bg-slate-800/50 transition-colors group">
                <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center flex-shrink-0 group-hover:bg-emerald-500/20 transition-colors">
                  <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon} />
                  </svg>
                </div>
                <div>
                  <p class="text-white font-semibold text-sm mb-0.5">{item.label}</p>
                  <p class="text-slate-400 text-sm">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── Services strip ────────────────────────────────────── -->
    <section class="bg-slate-900 py-24">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16" data-aos="fade-up">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-3">What We Do</p>
          <h2 class="font-display text-4xl md:text-5xl font-bold text-white tracking-tight">End-to-end energy solutions</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            {
              title: 'Development &\nFinancing',
              icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              points: ['Site assessment & permitting', 'Project finance structuring', 'PPA & offtake negotiation', 'Risk management'],
            },
            {
              title: 'EPC\nDelivery',
              icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              points: ['Engineering & design', 'Procurement & logistics', 'Construction management', 'Commissioning & testing'],
            },
            {
              title: 'O&M &\nRepowering',
              icon: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z',
              points: ['Remote monitoring & SCADA', 'Preventive & corrective M', 'Module & inverter upgrades', 'Performance optimisation'],
            },
          ].map((svc, i) => (
            <div class="glass rounded-2xl p-8 hover:bg-slate-800/40 transition-colors group" data-aos="fade-up" data-aos-delay={i * 100}>
              <div class="w-12 h-12 rounded-2xl bg-emerald-500/10 flex items-center justify-center mb-6 group-hover:bg-emerald-500/20 transition-colors">
                <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={svc.icon} />
                </svg>
              </div>
              <h3 class="font-display text-2xl font-bold text-white mb-4 whitespace-pre-line leading-tight">{svc.title}</h3>
              <ul class="space-y-2.5">
                {svc.points.map(pt => (
                  <li class="flex items-center gap-x-2.5 text-slate-400 text-sm">
                    <svg class="w-4 h-4 text-emerald-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {pt}
                  </li>
                ))}
              </ul>
              <a href="/services" class="inline-flex items-center gap-x-1.5 text-emerald-400 text-sm font-semibold mt-6 hover:text-emerald-300 transition-colors" style="min-height: auto;">
                Learn more
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <FeaturedProjects projects={featuredProjects} filterTypes={filterTypes} />

    <PartnershipCircles />

    <!-- ── Impact ────────────────────────────────────────────── -->
    <section class="bg-slate-900 py-24">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16" data-aos="fade-up">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-3">Environmental Impact</p>
          <h2 class="font-display text-4xl md:text-5xl font-bold text-white tracking-tight">Making a measurable difference</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { value: `~${cleanEnergyGWh}`, unit: 'GWh', label: 'Clean Energy Generated Annually', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
            { value: `~${co2Label}`, unit: 'tonnes', label: 'CO₂ Emissions Avoided Per Year', icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
            { value: '50+', unit: 'partners', label: 'Strategic Partners Across Asia', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },
          ].map((stat, i) => (
            <div class="glass rounded-2xl p-8 text-center" data-aos="fade-up" data-aos-delay={i * 100}>
              <div class="w-14 h-14 rounded-2xl bg-emerald-500/10 flex items-center justify-center mx-auto mb-5">
                <svg class="w-7 h-7 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={stat.icon} />
                </svg>
              </div>
              <p class="font-display text-4xl font-bold text-white mb-1">
                {stat.value}<span class="text-emerald-400 text-2xl ml-1">{stat.unit}</span>
              </p>
              <p class="text-slate-400 text-sm mt-1">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <SolarCalculator />

    <!-- ── Journey Timeline ──────────────────────────────────── -->
    <section class="bg-slate-900 py-24">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16" data-aos="fade-up">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-3">Our Journey</p>
          <h2 class="font-display text-4xl md:text-5xl font-bold text-white tracking-tight">10 years of clean energy leadership</h2>
        </div>
        <div class="relative max-w-3xl mx-auto">
          <div class="absolute left-5 top-0 bottom-0 w-px bg-slate-700"></div>
          <div class="space-y-10">
            {milestones.map((mile, i) => (
              <div class="flex gap-x-8 pl-12 relative" data-aos="fade-up" data-aos-delay={i * 80}>
                <div class="absolute left-0 top-1 w-10 h-10 rounded-full bg-slate-900 border-2 border-emerald-500 flex items-center justify-center flex-shrink-0">
                  <div class="w-2.5 h-2.5 rounded-full bg-emerald-500"></div>
                </div>
                <div>
                  <span class="text-emerald-400 text-sm font-semibold">{mile.year}</span>
                  <p class="text-slate-400 text-sm leading-relaxed mt-1">{mile.event}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── Final CTA ─────────────────────────────────────────── -->
    <section class="py-28 max-w-screen-2xl mx-auto px-6 lg:px-8">
      <div class="glass rounded-3xl p-10 md:p-16 text-center" data-aos="fade-up">
        <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-4">Get In Touch</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-white tracking-tight mb-4">
          Ready to start your<br />solar journey?
        </h2>
        <p class="text-slate-400 text-lg max-w-xl mx-auto mb-10">
          Whether you're looking for a development partner, EPC contractor, or
          long-term O&amp;M provider, our team is ready to help.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
          <a href="/contact" class="inline-flex items-center justify-center gap-x-2 px-8 py-4 bg-emerald-500 hover:bg-emerald-600 transition-colors text-slate-950 font-semibold rounded-full" style="min-height: auto;">
            Contact Our Team
          </a>
          <a href="/projects" class="inline-flex items-center justify-center gap-x-2 px-8 py-4 border border-slate-600 hover:border-slate-400 text-slate-300 hover:text-white transition-colors rounded-full font-semibold" style="min-height: auto;">
            View Portfolio
          </a>
        </div>
        <div class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm text-slate-500">
          <span>{ctaLabel}</span>
          {ctaPhone && (
            <>
              <span class="hidden sm:inline text-slate-700">·</span>
              <a href={`tel:${ctaPhone.replace(/\s+/g, '')}`} class="hover:text-slate-300 transition-colors" style="min-height: auto;">{ctaPhone}</a>
            </>
          )}
          <span class="hidden sm:inline text-slate-700">·</span>
          <a href={`mailto:${ctaEmail}`} class="text-emerald-500 hover:text-emerald-400 transition-colors" style="min-height: auto;">{ctaEmail}</a>
        </div>
      </div>
    </section>
  </main>
</Layout>
