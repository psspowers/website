---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import AnimatedStats from '../components/AnimatedStats.astro';
import { fetchProjects } from '../services/projectsDbService';

let activeProjects = 32;
let totalCapacityMW = 145;
let totalLocations = 19;
const co2Reduction = 137750;

try {
  const projects = await fetchProjects();
  if (projects.length > 0) {
    activeProjects = projects.length;
    totalCapacityMW = Math.round(
      projects.reduce((sum, p) => {
        if (p.capacity.includes('Well')) return sum;
        const n = parseFloat(p.capacity.replace(/[^\d.]/g, ''));
        return sum + (isNaN(n) ? 0 : n);
      }, 0)
    );
    totalLocations = new Set(projects.map(p => p.location)).size;
  }
} catch {
  // fall back to hardcoded values
}

const metrics = [
  { value: activeProjects, label: 'Active Projects', format: '+', icon: '/icons/projects/png/active-projects.png' },
  { value: totalCapacityMW, label: 'Total Capacity', format: 'MW', icon: '/icons/projects/png/total-capacity.png' },
  { value: totalLocations, label: 'Locations', format: '+', icon: '/icons/projects/png/total-sites.png' },
  { value: co2Reduction, label: 'CO2 Reduction/year', format: 'tons', icon: '/icons/projects/png/CO2 reduction.png' }
];
---

<Layout
  title="PSS Powers - Leading Renewable Energy Solutions Provider"
  description="PSS Powers delivers innovative solar, wind, and energy storage solutions across Asia. Partner with us for sustainable energy solutions and expert project development."
  image="https://images.unsplash.com/photo-1509391366360-2e959784a276?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80"
  type="website"
>
  <main>
    <!-- Hero Section -->
    <section class="relative h-screen flex items-center">
      <div class="absolute inset-0 z-0">
        <img
          src="https://images.unsplash.com/photo-1509391366360-2e959784a276?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80"
          alt="Solar panels"
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-black bg-opacity-50"></div>
      </div>
      
      <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-3xl" data-aos="fade-up">
          <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
            Powering a Sustainable Future
          </h1>
          <p class="text-xl text-white mb-8">
            Leading the renewable energy revolution with innovative solar and wind solutions.
          </p>
          <div class="flex space-x-4">
            <a href="/contact" class="btn btn-primary">Get Started</a>
            <a href="/projects" class="btn bg-white text-primary hover:bg-gray-100">View Projects</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Project Metrics Section -->
    <section class="bg-white py-16 border-b">
      <div class="container mx-auto px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {metrics.map((metric, index) => (
            <AnimatedStats
              value={metric.value}
              label={metric.label}
              format={metric.format}
              icon={metric.icon}
              delay={index * 100}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section class="section-padding bg-gray-50">
      <div class="container mx-auto px-6">
        <div class="text-center mb-16" data-aos="fade-up">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Our Services</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">
            We provide comprehensive renewable energy solutions to meet your sustainability goals.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white p-8 rounded-lg shadow-lg" data-aos="fade-up">
            <div class="mb-4 h-12 w-12">
              <img src="/icons/services/solar-energy.png" alt="Solar Energy Icon" class="w-full h-full object-contain"/>
            </div>
            <h3 class="text-xl font-bold mb-4">Solar Energy</h3>
            <p class="text-gray-600">
              Custom solar solutions for residential, commercial, and utility-scale projects.
            </p>
          </div>

          <div class="bg-white p-8 rounded-lg shadow-lg" data-aos="fade-up" data-aos-delay="100">
            <div class="mb-4 h-12 w-12">
              <img src="/icons/services/wind-power.png" alt="Wind Power Icon" class="w-full h-full object-contain"/>
            </div>
            <h3 class="text-xl font-bold mb-4">Wind Power</h3>
            <p class="text-gray-600">
              Harnessing wind energy with state-of-the-art turbine technology.
            </p>
          </div>

          <div class="bg-white p-8 rounded-lg shadow-lg" data-aos="fade-up" data-aos-delay="200">
            <div class="mb-4 h-12 w-12">
              <img src="/icons/services/energy-storage.png" alt="Energy Storage Icon" class="w-full h-full object-contain"/>
            </div>
            <h3 class="text-xl font-bold mb-4">Energy Storage</h3>
            <p class="text-gray-600">
              Advanced battery solutions for reliable energy storage and distribution.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="relative py-20">
      <div class="absolute inset-0 z-0">
        <img
          src="https://images.unsplash.com/photo-1466611653911-95081537e5b7?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80"
          alt="Wind turbines"
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-primary bg-opacity-90"></div>
      </div>
      
      <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-3xl mx-auto text-center text-white" data-aos="fade-up">
          <h2 class="text-3xl md:text-4xl font-bold mb-6">
            Ready to Switch to Renewable Energy?
          </h2>
          <p class="text-xl mb-8">
            Contact us today to discuss your energy needs and discover how we can help you achieve your sustainability goals.
          </p>
          <a href="/contact" class="btn bg-white text-primary hover:bg-gray-100">
            Get in Touch
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>