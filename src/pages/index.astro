            {[
              { year: '2015', title: 'Founded in Bangkok', desc: 'PSS Powers established with a mission to make renewable energy bankable across Southeast Asia.' },
              { year: '2018', title: '100 MW Milestone', desc: 'Crossed 100 MW of cumulative installed capacity, establishing PSS as a Tier-1 EPC contractor in Thailand.' },
