---
import Layout from '../layouts/Layout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import { supabase } from '../lib/supabase';

interface GroupCompany {
  id: string;
  name: string;
  url: string;
  description: string;
  features: string[];
  banner_image_url: string;
  logo_url: string | null;
  display_order: number;
}

const { data } = await supabase
  .from('group_companies')
  .select('*')
  .order('display_order', { ascending: true });

const websites: GroupCompany[] = (data as GroupCompany[]) ?? [];
---

<Layout
  title="PSS Group Network - Our Companies"
  description="Discover PSS Powers' diverse portfolio of companies and partners. From renewable energy to industrial solutions, explore our group's capabilities."
  type="website"
>
  <main class="pt-20">
    <!-- Hero -->
    <section class="dark-gradient-header">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="max-w-3xl text-white" data-aos="fade-up">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-4">The PSS Group</p>
          <h1 class="font-display text-4xl md:text-6xl font-bold tracking-tight mb-6">
            Our Group Network
          </h1>
          <p class="text-xl text-slate-300 leading-relaxed">
            Discover our diverse portfolio of companies and partners, each bringing unique value and expertise to our network.
          </p>
        </div>
      </div>
    </section>

    <!-- Companies Showcase -->
    <section class="py-20">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="space-y-12">
          {websites.map((site, index) => (
            <div class="glass rounded-2xl overflow-hidden" data-aos="fade-up" data-aos-delay={index * 80}>
              <div class="p-8 relative">
                <div class="flex items-start justify-between gap-6 mb-4">
                  <div>
                    <h2 class="font-display text-2xl font-bold text-white mb-1">{site.name}</h2>
                    <a
                      href={`https://${site.url}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-emerald-400 hover:text-emerald-300 transition-colors text-sm"
                      style="min-height: auto;"
                    >
                      {site.url}
                    </a>
                  </div>
                  {site.logo_url && (
                    <img
                      src={site.logo_url}
                      alt={`${site.name} logo`}
                      class="flex-shrink-0 h-10 w-auto object-contain"
                      style="mix-blend-mode: multiply; filter: brightness(1.8) contrast(1.2);"
                    />
                  )}
                </div>
                <p class="text-slate-400 text-sm leading-relaxed">{site.description}</p>
              </div>

              <div class="relative h-40 md:h-52 overflow-hidden">
                <OptimizedImage
                  src={site.banner_image_url}
                  alt={`${site.name} header`}
                  aspectRatio="16:5"
                  class="w-full h-full object-cover"
                  priority={index < 2}
                />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/60 via-slate-950/30 to-transparent pointer-events-none"></div>
              </div>

              <div class="p-8">
                <h3 class="text-white font-semibold mb-4">Key Features</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                  {site.features.map(feature => (
                    <div class="flex items-start gap-x-3 bg-slate-800/50 p-3 rounded-xl">
                      <svg class="w-4 h-4 flex-shrink-0 mt-0.5 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"/>
                      </svg>
                      <span class="text-slate-400 text-sm leading-tight">{feature}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 bg-slate-900">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8 text-center">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white tracking-tight mb-6" data-aos="fade-up">
          Interested in Collaboration?
        </h2>
        <p class="text-slate-400 mb-8 max-w-2xl mx-auto text-lg leading-relaxed" data-aos="fade-up" data-aos-delay="100">
          We're always open to new partnerships and opportunities. Reach out to learn more about our group companies and potential collaborations.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-x-2 px-8 py-4 bg-emerald-500 hover:bg-emerald-600 transition-colors text-slate-950 font-semibold rounded-full"
          data-aos="fade-up"
          data-aos-delay="200"
          style="min-height: auto;"
        >
          Contact Us
        </a>
      </div>
    </section>
  </main>
</Layout>
