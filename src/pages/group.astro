---
import Layout from '../layouts/Layout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';

const websites = [
  {
    name: 'One PSS',
    url: 'www.onepss.com',
    headerImage: '/PSS.RES.Banner.jpg?w=1920&h=640',
    colors: {
      primary: '#1a5f7a',
      secondary: '#2ecc71'
    },
    description: 'A leading provider of renewable energy solutions and power systems. One PSS specializes in delivering comprehensive services for improving energy efficiency and asset management of rotating machines besides providing leadering solutions with leading glogal companies. PSS Subsidiary company also manufactured Townson Expansion Joints and has PSS brand mechanical seals as well.',
    features: [
      'Energy efficiency & Hydraulic Upgrade for pumps',
      'Partner of OEMS like Siemens, Sulzer, John Crane, etc',
      'Service and turnaround of machines',
      'Gas Turbine parts & refurbrishment with AP&M',
      'Expansion Joints - fabric & metallic',
      'Engineered and Material Upgrade Parts'
    ]
  },
  {
    name: 'TA-TO',
    url: 'www.ta-to.com',
    headerImage: '/Tato.Banner.jpg?w=1920&h=640',
    colors: {
      primary: '#0088cc',
      secondary: '#005580'
    },
    description: 'TA-TO is your trusted source for contact lenses and eye care products. We offer a wide selection of premium contact lenses from leading brands, ensuring quality and comfort for your vision needs.',
    features: [
      'Premium Contact Lenses',
      'Leading Eye Care Brands',
      'Professional Consultation',
      'Fast & Reliable Delivery'
    ]
  },
  {
    name: 'Pizza Mania',
    url: 'www.pizzamania.com',
    headerImage: '/PizzaMania.Banner.jpg?w=1920&h=640',
    colors: {
      primary: '#d35400',
      secondary: '#e74c3c'
    },
    description: 'An authentic New York style pizza bringing the true taste of NYC to your table. Pizza Mania combines traditional recipes with modern culinary innovation.',
    features: [
      'Authentic NY Pizza',
      'Regenerative Farm Products',
      'Key Imported Ingedients',
      'Fast Deliveries in Town'
    ]
  },
  {
    name: 'Le Lapin Bangkok',
    url: 'www.LeLapinbangkok.com',
    headerImage: 'https://images.unsplash.com/photo-1509440159596-0249088772ff?ixlib=rb-1.2.1&auto=format&fit=crop&w=1800&h=600&q=80',
    colors: {
      primary: '#2c3e50',
      secondary: '#34495e'
    },
    description: 'A sophisticated European style sandwich cloud kitchen in the heart of Bangkok, offering an exquisite experience.',
    features: [
      'All Eurpean bread',
      'Regenerative farm products',
      'Imported European ingredients',
      'Most deliciuos sauces'
    ]
  },
  {
    name: 'Y Cube India',
    url: 'www.ycubeindia.com',
    headerImage: '/YCUBE.IRR.Banner.jpg?w=1920&h=640',
    colors: {
      primary: '#8e44ad',
      secondary: '#9b59b6'
    },
    description: 'An innovative technology solutions provider and system integrator in pressurized irrigation systems . Y Cube India has developed large utility valves upto 2 meter for industry and water under the brand YES Valves.',
    features: [
      'Pressurized Irrigation Expert',
      'System Integrator',
      'Valve Manufacturer',
      'Solar EPC'
    ]
  }
];
---

<Layout
  title="PSS Group Network - Our Companies"
  description="Discover PSS Powers' diverse portfolio of companies and partners. From renewable energy to industrial solutions, explore our group's capabilities."
  image="/PSS>RES>Logo.jpg"
  type="website"
>
  <main class="pt-20">
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-[#1E3D59] to-[#4F94CD] py-24 relative overflow-hidden">
      <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
      <div class="container mx-auto px-6">
        <h1 class="text-4xl md:text-6xl font-bold text-center mb-6 text-white" data-aos="fade-up">
          Our Group Network
        </h1>
        <p class="text-xl text-white/90 text-center max-w-3xl mx-auto" data-aos="fade-up" data-aos-delay="100">
          Discover our diverse portfolio of companies and partners, each bringing unique value and expertise to our network.
        </p>
      </div>
    </section>

    <!-- Websites Showcase -->
    <section class="py-24 bg-gray-50">
      <div class="container mx-auto px-6">
        <div class="space-y-16">
          {websites.map((site, index) => (
            <div class="group" data-aos="fade-up" data-aos-delay={index * 100}>
              <div class="bg-white rounded-2xl shadow-xl overflow-hidden transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl">
                <div class="p-6 relative">
                  <h2 class="text-3xl font-bold text-gray-800 mb-2">
                    {site.name}
                    {site.name === 'One PSS' && (
                      <img
                        src="/PSS.RES.Logo.jpg"
                        alt="PSS Group Logo"
                        class="absolute top-6 right-6 h-14 w-auto object-contain"
                      />
                    )}
                  </h2>
                  <a
                    href={`https://${site.url}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block text-primary hover:text-primary/80 transition-colors text-base mb-4"
                  >
                    {site.url}
                  </a>
                  <p class="text-gray-600 text-sm leading-relaxed">
                    {site.description}
                  </p>
                </div>
                <div class="relative h-40 md:h-48 border-y border-gray-100 bg-gray-50">
                  <OptimizedImage
                    src={site.headerImage}
                    alt={`${site.name} header`}
                    aspectRatio="16:5"
                    class={`w-full h-full object-contain p-6 ${site.name === 'One PSS' ? 'opacity-90' : ''}`}
                    priority={index < 2}
                  />
                </div>
                <div class="p-6">
                  <div>
                    <h3 class="text-lg font-semibold mb-3 text-gray-800">Key Features</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                      {site.features.map(feature => (
                        <div class="flex items-start space-x-3 bg-gray-50 p-3 rounded-lg">
                          <svg
                            class="w-4 h-4 flex-shrink-0 mt-1"
                            style={`color: ${site.colors.primary}`}
                            fill="currentColor"
                            viewBox="0 0 20 20"
                          >
                            <path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"/>
                          </svg>
                          <span class="text-gray-700 text-sm leading-tight">{feature}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="bg-primary py-20">
      <div class="container mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold mb-6 text-white" data-aos="fade-up">
          Interested in Collaboration?
        </h2>
        <p class="text-white/90 mb-8 max-w-2xl mx-auto text-lg" data-aos="fade-up" data-aos-delay="100">
          We're always open to new partnerships and opportunities. Reach out to learn more about our group companies and potential collaborations.
        </p>
        <a
          href="/contact"
          class="inline-block bg-white text-primary px-8 py-4 rounded-lg hover:bg-gray-100 transition-colors font-semibold text-lg"
          data-aos="fade-up"
          data-aos-delay="200"
        >
          Contact Us
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .bg-grid-pattern {
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M54.627 0l.83.828-1.415 1.415L51.8 0h2.827zM5.373 0l-.83.828L5.96 2.243 8.2 0H5.374zM48.97 0l3.657 3.657-1.414 1.414L46.143 0h2.828zM11.03 0L7.372 3.657 8.787 5.07 13.857 0H11.03zm32.284 0L49.8 6.485 48.384 7.9l-7.9-7.9h2.83zM16.686 0L10.2 6.485 11.616 7.9l7.9-7.9h-2.83zM22.343 0L13.857 8.485 15.272 9.9l7.9-7.9h-.83zm5.657 0L19.514 8.485 20.93 9.9l8.485-8.485h-1.414zM32.372 0L22.343 10.03 23.758 11.444l10.03-10.03h-1.415zm-1.415 0L19.514 11.444l1.414 1.414L34.2 0h-3.242zm-5.657 0L13.857 11.444l1.415 1.414L29.543 0h-3.243zM11.03 0L0 11.03l1.414 1.414L13.857 0h-2.827zm32.284 0L51.8 8.485 50.384 7.07 44.728 0h-1.414zm-16.97 0L36.9 10.456 38.315 9.04 29.828 0h-3.242zm10.657 0L47.557 10.456 48.97 9.04 40.485 0h-3.243zM16.686 0L4.242 12.444l1.415 1.414L19.514 0h-2.828zM5.373 0L0 5.373l1.414 1.414L8.2 0H5.374zm48.97 0L60 5.373l-1.414 1.414L51.8 0h2.827zM54.627 0L60 5.373 58.586 6.787 51.8 0h2.827zm-48.97 0L0 5.373 1.414 6.787 8.2 0H5.657z' fill='%23ffffff' fill-opacity='0.4' fill-rule='evenodd'/%3E%3C/svg%3E");
  }
</style>