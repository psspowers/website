---
import Layout from '../layouts/Layout.astro';
import LinkText from '../components/LinkText.astro';
import FinancialPartnerBadge from '../components/FinancialPartnerBadge.astro';
import AnimatedStats from '../components/AnimatedStats.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import { supabase } from '../lib/supabase';

const stats = [
  { value: 450, label: 'Total Project Pipeline', format: 'MW' },
  { value: 5, label: 'Countries Served', format: '+' },
  { value: 70, label: 'Employees Worldwide', format: '+' },
  { value: 100, label: 'Projects Completed', format: '+' },
];

const staticLeaders = [
  { name: 'Sam Yamdagni', role: 'CEO & JMD', image: '/Team/Sam.jpg', bio: 'Leading PSS Powers with strategic vision and extensive industry experience.' },
  { name: 'Nikesh Sinha', role: 'JMD', image: '/Team/Nikesh.jpg', bio: 'Leading PSS Powers with strategic vision and extensive industry experience.' },
  { name: 'Nakkarin Saingarmsatit', role: 'GM & Director', image: '/Team/Nakkarin.jpg', bio: 'Overseeing Project Development & execution in Thailand.' },
  { name: 'Suraphol Sanyom', role: 'Head, Construction O&M', image: '/Team/Suraphol.jpg', bio: 'Leading construction operations and maintenance with proven expertise.' },
  { name: 'Ashish Kumar', role: 'Head, Investment & Transac.', image: '/Team/Ashish.jpg', bio: 'Leading investment strategies and transaction management.' },
  { name: 'Chudapak Juthachutinan', role: 'Head, Finance & Accounts', image: '/Team/Chudapak.jpg', bio: 'Overseeing financial operations and accounting excellence in Thailand.' },
  { name: 'Kapil Joshi', role: 'Head, Finance & Accounts', image: '/Team/Kapil.jpg', bio: 'Overseeing financial operations and accounting excellence in India.' },
  { name: 'Pimlapat Boonthae', role: 'Renewable Energy Marketing Lead', image: '/Team/Pimlapat.jpg', bio: 'Drives brand decarbonization engagement and Marketing.' }
];

const { data: dbLeaders } = await supabase
  .from('team_members')
  .select('name, role, bio, image_url')
  .eq('is_visible', true)
  .order('display_order', { ascending: true });

const leaders = dbLeaders && dbLeaders.length > 0
  ? dbLeaders.map(m => ({ name: m.name, role: m.role, bio: m.bio, image: m.image_url ?? '' }))
  : staticLeaders;

const milestones = [
  { year: '2012', event: 'APCA Powers invest in first 5.0 MW solar plant' },
  { year: '2015', event: 'PSS Powers founded with a vision for renewable energy' },
  { year: '2016', event: 'Completed first utility-scale solar project (5+1 MW)' },
  { year: '2017', event: 'Expanded operations into EPC Business' },
  { year: '2019', event: 'Started C&I Business' },
  { year: '2022', event: 'Expanded in to India with 60 MW under open access' },
  { year: '2024', event: 'Complete execution of 105 MW' },
  { year: '2025', event: 'Signed agreement to partner with I Squared Capital' }
];
---

<Layout
  title="About PSS Powers - Leading Renewable Energy Provider"
  description="Learn about PSS Powers' journey in renewable energy, our expert team, and partnership with I Squared Capital. Discover how we're shaping a sustainable future."
  image="/i-squared-capital-logo.png"
  type="website"
>
  <main class="pt-20">
    <!-- Hero -->
    <section class="dark-gradient-header relative">
      <FinancialPartnerBadge class="absolute top-6 right-6 lg:top-8 lg:right-12 z-50" />
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="max-w-3xl text-white" data-aos="fade-up">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-4">Who We Are</p>
          <h1 class="font-display text-4xl md:text-5xl font-bold tracking-tight mb-6">
            Our Journey in Renewable Energy
          </h1>
          <p class="text-xl text-slate-300 leading-relaxed">
            Since 2012, PSS Powers has been at the forefront of the renewable energy revolution,
            delivering innovative solutions and driving sustainable change across Asia.
          </p>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="py-12 bg-slate-900">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {stats.map((stat, index) => (
            <AnimatedStats value={stat.value} label={stat.label} format={stat.format} delay={index * 100} />
          ))}
        </div>
      </div>
    </section>

    <!-- History -->
    <section class="py-20">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-12" data-aos="fade-up">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-3">Background</p>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white tracking-tight">From Yesterday to Today</h2>
        </div>
        <div class="max-w-4xl mx-auto">
          <div class="glass rounded-2xl p-8 md:p-10" data-aos="fade-up" data-aos-delay="100">
            <p class="text-slate-400 mb-8 leading-relaxed">
              PSS Powers, an independent energy producer, was founded in 2012 through the collaboration of two industry leaders with complementary expertise.
            </p>
            <div class="space-y-6">
              <div class="border-l-2 border-emerald-500 pl-6">
                <p class="text-slate-300 leading-relaxed">
                  Sam Yamdagni entered the renewable energy sector in 2015, developing over 100 MW of projects with an in-house EPC and O&M team. He previously served as Country Head of the ib Vogt JV in Thailand and as MD APAC for Amarenco JV. He is a graduate of IIT Kharagpur.
                </p>
              </div>
              <div class="border-l-2 border-emerald-500 pl-6">
                <p class="text-slate-300 leading-relaxed">
                  Nikesh Sinha has been in the renewable energy industry since 2011, developing over 350 MW of projects. He previously led investment for ib Vogt in APAC under the NV Vogt JV. He holds degrees from IIT Chennai and IIM Ahmedabad.
                </p>
              </div>
            </div>
            <p class="text-slate-400 mt-8 leading-relaxed">
              With their combined expertise, PSS Powers has established itself as a trusted partner for renewable energy investments in the region, driving sustainable growth and innovation with a strong pipeline.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Leadership -->
    <section class="py-20 bg-slate-900">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16" data-aos="fade-up">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-3">The Team</p>
          <h2 class="font-display text-4xl font-bold text-white tracking-tight mb-4">Our Leadership</h2>
          <p class="text-slate-400 text-lg max-w-2xl mx-auto">
            Meet the team driving innovation and excellence in renewable energy solutions across Asia.
          </p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {leaders.map((leader, index) => (
            <div
              class="glass rounded-2xl overflow-hidden group hover:bg-slate-800/40 transition-colors"
              data-aos="fade-up"
              data-aos-delay={index * 80}
            >
              <div class="relative aspect-[4/3] overflow-hidden">
                <OptimizedImage
                  src={leader.image}
                  alt={leader.name}
                  aspectRatio="4:3"
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  priority={index < 4}
                />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/60 to-transparent"></div>
              </div>
              <div class="p-5">
                <h3 class="text-white font-semibold text-lg mb-0.5">{leader.name}</h3>
                <p class="text-emerald-400 text-xs font-semibold uppercase tracking-wider mb-2">{leader.role}</p>
                <p class="text-slate-400 text-sm">{leader.bio}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="mt-12 text-center">
          <a href="/contact" class="inline-flex items-center gap-x-2 text-emerald-400 hover:text-emerald-300 font-semibold transition-colors" style="min-height: auto;">
            Join Our Team
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Mission -->
    <section class="py-20 solar-gradient">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-4" data-aos="fade-up">Purpose</p>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white tracking-tight mb-6" data-aos="fade-up">Our Mission</h2>
          <p class="text-xl text-slate-300 leading-relaxed" data-aos="fade-up" data-aos-delay="100">
            To accelerate the transition to sustainable energy by providing innovative renewable solutions
            that empower businesses and communities to achieve their environmental goals while ensuring economic benefits.
          </p>
        </div>
      </div>
    </section>

    <!-- Milestones -->
    <section class="py-20 bg-slate-900">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16" data-aos="fade-up">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-3">Timeline</p>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white tracking-tight">Our Journey</h2>
        </div>
        <div class="max-w-3xl mx-auto relative">
          <div class="absolute left-[3.5rem] top-0 bottom-0 w-px bg-slate-700"></div>
          <div class="space-y-6">
            {milestones.map((milestone, index) => (
              <div class="flex items-start gap-x-6" data-aos="fade-up" data-aos-delay={index * 60}>
                <div class="w-14 text-right flex-shrink-0">
                  <span class="text-emerald-400 font-bold text-sm">{milestone.year}</span>
                </div>
                <div class="relative flex-shrink-0">
                  <div class="w-4 h-4 rounded-full border-2 border-emerald-500 bg-slate-900 relative z-10 mt-0.5"></div>
                </div>
                <div class="glass rounded-xl p-4 flex-1 flex items-center justify-between gap-x-4">
                  <p class="text-slate-300 text-sm leading-relaxed">
                    <LinkText text={milestone.event} />
                  </p>
                  {milestone.year === '2025' && (
                    <a href="https://isquaredcapital.com/" target="_blank" rel="noopener noreferrer" class="flex-shrink-0" style="min-height: auto;">
                      <img
                        src="/i-squared-capital-logo.png"
                        alt="I Squared Capital Logo"
                        class="h-8 w-auto transition-all duration-300 hover:opacity-80"
                        style="mix-blend-mode: multiply; filter: brightness(1.8) contrast(1.2);"
                      />
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="py-20">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-16" data-aos="fade-up">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-3">Principles</p>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white tracking-tight">Our Values</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { title: 'Innovation', desc: 'Continuously pushing boundaries to develop and implement cutting-edge renewable energy solutions.' },
            { title: 'Sustainability', desc: 'Committed to environmental stewardship and promoting sustainable practices in everything we do.' },
            { title: 'Excellence', desc: 'Delivering superior quality and reliability in every project and service we provide.' },
          ].map((v, i) => (
            <div class="glass rounded-2xl p-8" data-aos="fade-up" data-aos-delay={i * 100}>
              <h3 class="text-emerald-400 font-bold text-xl mb-3">{v.title}</h3>
              <p class="text-slate-400 leading-relaxed">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 bg-slate-900">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8 text-center">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white tracking-tight mb-6" data-aos="fade-up">
          Join Us in Shaping a Sustainable Future
        </h2>
        <p class="text-slate-400 text-lg mb-8 max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="100">
          Partner with PSS Powers to accelerate your transition to renewable energy and contribute to a cleaner, more sustainable world.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-x-2 px-8 py-4 bg-emerald-500 hover:bg-emerald-600 transition-colors text-slate-950 font-semibold rounded-full"
          data-aos="fade-up"
          data-aos-delay="200"
          style="min-height: auto;"
        >
          Contact Us
        </a>
      </div>
    </section>
  </main>
</Layout>
