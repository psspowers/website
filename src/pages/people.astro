---
import Layout from '../layouts/Layout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import FinancialPartnerBadge from '../components/FinancialPartnerBadge.astro';
import { supabase } from '../lib/supabase';

const { data: members } = await supabase
  .from('team_members')
  .select('name, role, bio, image_url, linkedin_url')
  .eq('is_visible', true)
  .order('display_order', { ascending: true });

const people = members ?? [];
---

<Layout
  title="Our Team — PSS Powers"
  description="Meet the leadership and team driving renewable energy innovation across Asia at PSS Powers."
>
  <main class="pt-20">
    <!-- Hero -->
    <section class="dark-gradient-header relative">
      <FinancialPartnerBadge class="absolute top-6 right-6 lg:top-8 lg:right-12 z-50" />
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="max-w-3xl text-white" data-aos="fade-up">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-4">The Team</p>
          <h1 class="font-display text-4xl md:text-5xl font-bold tracking-tight mb-6">
            People Behind the Mission
          </h1>
          <p class="text-xl text-slate-300 leading-relaxed">
            Our leadership team brings decades of combined experience in renewable energy development, investment, and operations across Asia.
          </p>
        </div>
      </div>
    </section>

    <!-- Team Grid -->
    <section class="py-20">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {people.map((person, index) => (
            <div
              class="glass rounded-2xl overflow-hidden group hover:bg-slate-800/40 transition-colors flex flex-col"
              data-aos="fade-up"
              data-aos-delay={Math.min(index * 60, 400)}
            >
              <div class="relative aspect-[4/3] overflow-hidden">
                <OptimizedImage
                  src={person.image_url ?? ''}
                  alt={person.name}
                  aspectRatio="4:3"
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  priority={index < 4}
                />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/60 to-transparent"></div>
              </div>
              <div class="p-6 flex flex-col flex-1">
                <div class="flex-1">
                  <h2 class="text-white font-semibold text-lg leading-snug mb-1">{person.name}</h2>
                  <p class="text-emerald-400 text-xs font-semibold uppercase tracking-wider mb-3">{person.role}</p>
                  <p class="text-slate-400 text-sm leading-relaxed">{person.bio}</p>
                </div>
                {person.linkedin_url && (
                  <div class="mt-4 pt-4 border-t border-slate-700/50">
                    <a
                      href={person.linkedin_url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 text-sm text-[#0077b5] hover:text-[#005f8e] font-medium transition-colors"
                      style="min-height: auto;"
                    >
                      <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                      </svg>
                      Connect on LinkedIn
                    </a>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Join CTA -->
    <section class="py-20 bg-slate-900">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8 text-center">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white tracking-tight mb-6" data-aos="fade-up">
          Want to Join the Team?
        </h2>
        <p class="text-slate-400 text-lg mb-8 max-w-xl mx-auto" data-aos="fade-up" data-aos-delay="100">
          We're always looking for talented people who share our passion for renewable energy and sustainable development.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-x-2 px-8 py-4 bg-emerald-500 hover:bg-emerald-600 transition-colors text-slate-950 font-semibold rounded-full"
          data-aos="fade-up"
          data-aos-delay="200"
          style="min-height: auto;"
        >
          Get in Touch
        </a>
      </div>
    </section>
  </main>
</Layout>
