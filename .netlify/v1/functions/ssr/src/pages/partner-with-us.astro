---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Partner With PSS Orange - Strategic Collaboration"
  description="Partner with PSS Orange to build Asia's clean energy future. Explore strategic, investment, EPC, and technology partnership opportunities."
  type="website"
>
  <main class="pt-20">

    <!-- Hero -->
    <section class="dark-gradient-header">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="max-w-3xl text-white" data-aos="fade-up">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-4">Partnerships</p>
          <h1 class="font-display text-4xl md:text-5xl font-bold tracking-tight mb-6">
            Partner With PSS Orange
          </h1>
          <p class="text-xl text-slate-300 leading-relaxed">
            Let's build Asia's clean energy future together through strategic collaboration and project execution.
          </p>
        </div>
      </div>
    </section>

    <!-- Partnership Cards -->
    <section class="py-20">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-14" data-aos="fade-up">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-3">Collaborate With Us</p>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white tracking-tight">
            How would you like to partner with us?
          </h2>
        </div>

        <!-- 4 Main Cards -->
        <div class="grid md:grid-cols-2 gap-6 mb-8" data-aos="fade-up" data-aos-delay="100">

          <!-- Strategic Partnership -->
          <div class="glass rounded-2xl p-8 flex flex-col gap-5 group hover:border-emerald-500/30 transition-all duration-300 hover:-translate-y-1">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div>
                <h3 class="text-white font-bold text-lg mb-2">Strategic Partnership</h3>
                <p class="text-slate-400 text-sm leading-relaxed">
                  Explore joint development and co-investment opportunities across solar, wind, hybrid, and BESS projects in Asia.
                </p>
              </div>
            </div>
            <button
              class="mt-auto self-start inline-flex items-center gap-x-2 px-5 py-2.5 bg-emerald-500 hover:bg-emerald-600 text-slate-950 font-semibold text-sm rounded-full transition-colors"
              style="min-height: auto;"
              data-modal="strategic"
            >
              Express Interest
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </div>

          <!-- Investment & Capital Partner -->
          <div class="glass rounded-2xl p-8 flex flex-col gap-5 group hover:border-emerald-500/30 transition-all duration-300 hover:-translate-y-1">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-white font-bold text-lg mb-2">Investment & Capital Partner</h3>
                <p class="text-slate-400 text-sm leading-relaxed">
                  Partner with us on project financing and capital raising for utility-scale renewable energy assets.
                </p>
              </div>
            </div>
            <button
              class="mt-auto self-start inline-flex items-center gap-x-2 px-5 py-2.5 bg-emerald-500 hover:bg-emerald-600 text-slate-950 font-semibold text-sm rounded-full transition-colors"
              style="min-height: auto;"
              data-modal="investment"
            >
              Express Interest
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </div>

          <!-- EPC & Project Execution Partner -->
          <div class="glass rounded-2xl p-8 flex flex-col gap-5 group hover:border-emerald-500/30 transition-all duration-300 hover:-translate-y-1">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              </div>
              <div>
                <h3 class="text-white font-bold text-lg mb-2">EPC & Project Execution Partner</h3>
                <p class="text-slate-400 text-sm leading-relaxed">
                  Collaborate with our experienced EPC team on engineering, procurement, and construction of renewable energy projects.
                </p>
              </div>
            </div>
            <button
              class="mt-auto self-start inline-flex items-center gap-x-2 px-5 py-2.5 bg-emerald-500 hover:bg-emerald-600 text-slate-950 font-semibold text-sm rounded-full transition-colors"
              style="min-height: auto;"
              data-modal="epc"
            >
              Express Interest
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </div>

          <!-- Technology & Supply Partner -->
          <div class="glass rounded-2xl p-8 flex flex-col gap-5 group hover:border-emerald-500/30 transition-all duration-300 hover:-translate-y-1">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" />
                </svg>
              </div>
              <div>
                <h3 class="text-white font-bold text-lg mb-2">Technology & Supply Partner</h3>
                <p class="text-slate-400 text-sm leading-relaxed">
                  Work with us as a technology or equipment partner across solar, BESS, and power systems.
                </p>
              </div>
            </div>
            <button
              class="mt-auto self-start inline-flex items-center gap-x-2 px-5 py-2.5 bg-emerald-500 hover:bg-emerald-600 text-slate-950 font-semibold text-sm rounded-full transition-colors"
              style="min-height: auto;"
              data-modal="technology"
            >
              Express Interest
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Secondary Options -->
        <div class="glass rounded-2xl divide-y divide-slate-800/60" data-aos="fade-up" data-aos-delay="200">
          <button
            class="w-full flex items-center justify-between px-8 py-5 text-left group hover:bg-slate-800/30 transition-colors rounded-t-2xl"
            style="min-height: auto;"
            data-modal="careers"
          >
            <div>
              <span class="text-white font-semibold text-base">Join Our Team</span>
              <p class="text-slate-400 text-sm mt-0.5">Interested in a career at PSS Orange? We'd love to hear from you.</p>
            </div>
            <svg class="w-5 h-5 text-slate-500 group-hover:text-emerald-400 transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
          <button
            class="w-full flex items-center justify-between px-8 py-5 text-left group hover:bg-slate-800/30 transition-colors rounded-b-2xl"
            style="min-height: auto;"
            data-modal="other"
          >
            <div>
              <span class="text-white font-semibold text-base">Other Inquiries</span>
              <p class="text-slate-400 text-sm mt-0.5">Have a different question or proposal? Send us a message.</p>
            </div>
            <svg class="w-5 h-5 text-slate-500 group-hover:text-emerald-400 transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
      </div>
    </section>

    <!-- Why Partner With Us -->
    <section class="py-20 bg-slate-900">
      <div class="max-w-screen-2xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-14" data-aos="fade-up">
          <p class="text-emerald-400 text-sm font-semibold tracking-widest uppercase mb-3">Our Track Record</p>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white tracking-tight">
            Why Partner with PSS Orange
          </h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="glass rounded-2xl p-7" data-aos="fade-up" data-aos-delay="0">
            <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <p class="text-2xl font-bold text-white mb-2">450+ MW</p>
            <p class="text-slate-400 text-sm leading-relaxed">Active project pipeline across solar, wind, hybrid, and BESS energy systems in Asia.</p>
          </div>
          <div class="glass rounded-2xl p-7" data-aos="fade-up" data-aos-delay="80">
            <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <p class="text-2xl font-bold text-white mb-2">In House EPCM and O&M</p>
            <p class="text-slate-400 text-sm leading-relaxed">We partner with strong EPC companies and execute contracts and O&M with internal teams.</p>
          </div>
          <div class="glass rounded-2xl p-7" data-aos="fade-up" data-aos-delay="160">
            <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <p class="text-2xl font-bold text-white mb-2">6 Countries</p>
            <p class="text-slate-400 text-sm leading-relaxed">Established presence and active operations across six countries in Asia.</p>
          </div>
          <div class="glass rounded-2xl p-7" data-aos="fade-up" data-aos-delay="240">
            <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            </div>
            <p class="text-2xl font-bold text-white mb-2">Bankable Projects</p>
            <p class="text-slate-400 text-sm leading-relaxed">A proven track record of delivering bankable projects with institutional-grade documentation.</p>
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- Modal Overlay -->
  <div id="partner-modal" class="fixed inset-0 z-[200] hidden">
    <div class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm" id="modal-backdrop"></div>
    <div class="relative flex items-center justify-center min-h-screen p-4">
      <div class="relative w-full max-w-lg glass rounded-2xl shadow-2xl" id="modal-panel">
        <!-- Header -->
        <div class="flex items-center justify-between px-8 pt-8 pb-4 border-b border-slate-800/60">
          <h3 id="modal-title" class="text-white font-bold text-xl"></h3>
          <button
            id="modal-close"
            class="w-8 h-8 flex items-center justify-center text-slate-400 hover:text-white transition-colors rounded-lg hover:bg-slate-800"
            style="min-height: auto; min-width: auto;"
            aria-label="Close"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Form Container -->
        <div class="px-8 py-6 max-h-[70vh] overflow-y-auto">

          <!-- Common fields (shared across all forms) -->
          <div class="space-y-4 mb-5">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-name">Full Name*</label>
                <input type="text" id="f-name" name="name" required class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all text-sm" />
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-email">Email*</label>
                <input type="email" id="f-email" name="email" required class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all text-sm" />
              </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-company">Company</label>
                <input type="text" id="f-company" name="company" class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all text-sm" />
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-country">Country</label>
                <input type="text" id="f-country" name="country" class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all text-sm" />
              </div>
            </div>
          </div>

          <!-- Type-specific fields (shown/hidden by JS) -->

          <!-- Strategic -->
          <div id="fields-strategic" class="hidden space-y-4">
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-project-type">Project Type</label>
              <select id="f-project-type" name="project_type" class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all text-sm" style="min-height: auto;">
                <option value="" class="bg-slate-800">Select project type</option>
                <option value="solar" class="bg-slate-800">Solar PV</option>
                <option value="wind" class="bg-slate-800">Wind</option>
                <option value="hybrid" class="bg-slate-800">Hybrid (Solar + BESS)</option>
                <option value="bess" class="bg-slate-800">Battery Energy Storage (BESS)</option>
                <option value="other" class="bg-slate-800">Other</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-geography">Preferred Geography</label>
              <input type="text" id="f-geography" name="geography" placeholder="e.g. Thailand, India, Southeast Asia" class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all text-sm" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-collab-goals">Collaboration Goals</label>
              <textarea id="f-collab-goals" name="collaboration_goals" rows="3" placeholder="Briefly describe what you're looking to achieve..." class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all resize-none text-sm"></textarea>
            </div>
          </div>

          <!-- Investment -->
          <div id="fields-investment" class="hidden space-y-4">
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-investment-size">Investment Size (USD)</label>
              <select id="f-investment-size" name="investment_size" class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all text-sm" style="min-height: auto;">
                <option value="" class="bg-slate-800">Select range</option>
                <option value="<5m" class="bg-slate-800">Under $5M</option>
                <option value="5-20m" class="bg-slate-800">$5M – $20M</option>
                <option value="20-50m" class="bg-slate-800">$20M – $50M</option>
                <option value="50-100m" class="bg-slate-800">$50M – $100M</option>
                <option value=">100m" class="bg-slate-800">$100M+</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-thesis">Investment Thesis</label>
              <input type="text" id="f-thesis" name="investment_thesis" placeholder="e.g. Greenfield solar, secondary market, project debt..." class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all text-sm" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-returns">Target Returns / IRR Expectations</label>
              <input type="text" id="f-returns" name="target_returns" placeholder="e.g. 10–14% IRR" class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all text-sm" />
            </div>
          </div>

          <!-- EPC -->
          <div id="fields-epc" class="hidden space-y-4">
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-capabilities">Core Capabilities</label>
              <input type="text" id="f-capabilities" name="capabilities" placeholder="e.g. Civil, electrical, procurement, commissioning..." class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all text-sm" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-regions">Regions of Interest</label>
              <input type="text" id="f-regions" name="regions_of_interest" placeholder="e.g. Thailand, Vietnam, India" class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all text-sm" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-experience">Relevant Experience</label>
              <textarea id="f-experience" name="relevant_experience" rows="3" placeholder="Briefly describe key projects or track record..." class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all resize-none text-sm"></textarea>
            </div>
          </div>

          <!-- Technology -->
          <div id="fields-technology" class="hidden space-y-4">
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-products">Products / Services Offered</label>
              <input type="text" id="f-products" name="products_services" placeholder="e.g. Solar modules, inverters, BESS systems, monitoring..." class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all text-sm" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-scale">Scale of Supply</label>
              <select id="f-scale" name="scale_of_supply" class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all text-sm" style="min-height: auto;">
                <option value="" class="bg-slate-800">Select capacity</option>
                <option value="<10mw" class="bg-slate-800">Under 10 MW/year</option>
                <option value="10-50mw" class="bg-slate-800">10 – 50 MW/year</option>
                <option value="50-200mw" class="bg-slate-800">50 – 200 MW/year</option>
                <option value=">200mw" class="bg-slate-800">200 MW+/year</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-tech-message">Additional Details</label>
              <textarea id="f-tech-message" name="message" rows="3" placeholder="Any other information you'd like to share..." class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all resize-none text-sm"></textarea>
            </div>
          </div>

          <!-- Careers -->
          <div id="fields-careers" class="hidden space-y-4">
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-careers-message">Tell Us About Yourself</label>
              <textarea id="f-careers-message" name="message" rows="4" placeholder="Share your background, skills, and what role you're interested in..." class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all resize-none text-sm"></textarea>
            </div>
          </div>

          <!-- Other -->
          <div id="fields-other" class="hidden space-y-4">
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-1.5" for="f-other-message">Your Message*</label>
              <textarea id="f-other-message" name="message" rows="4" required placeholder="How can we help you?" class="w-full px-4 py-2.5 rounded-xl bg-slate-800/60 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 transition-all resize-none text-sm"></textarea>
            </div>
          </div>

          <!-- Submit -->
          <div class="mt-6">
            <button
              id="modal-submit"
              type="button"
              class="w-full bg-emerald-500 hover:bg-emerald-600 text-slate-950 py-3 px-6 rounded-xl font-semibold transition-colors text-sm"
              style="min-height: auto;"
            >
              Submit
            </button>
            <p id="modal-status" class="text-sm mt-3 text-center"></p>
          </div>

        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.VITE_SUPABASE_URL,
    import.meta.env.VITE_SUPABASE_ANON_KEY
  );

  const modal = document.getElementById('partner-modal')!;
  const backdrop = document.getElementById('modal-backdrop')!;
  const closeBtn = document.getElementById('modal-close')!;
  const titleEl = document.getElementById('modal-title')!;
  const submitBtn = document.getElementById('modal-submit') as HTMLButtonElement;
  const statusEl = document.getElementById('modal-status')!;

  const allFieldSections = ['strategic', 'investment', 'epc', 'technology', 'careers', 'other'];

  const modalConfig: Record<string, { title: string }> = {
    strategic:  { title: 'Strategic Partnership' },
    investment: { title: 'Investment & Capital Partner' },
    epc:        { title: 'EPC & Project Execution Partner' },
    technology: { title: 'Technology & Supply Partner' },
    careers:    { title: 'Join Our Team' },
    other:      { title: 'Other Inquiries' },
  };

  let activeType = '';

  function openModal(type: string) {
    activeType = type;
    const cfg = modalConfig[type];
    if (!cfg) return;

    titleEl.textContent = cfg.title;
    statusEl.textContent = '';
    submitBtn.disabled = false;
    submitBtn.textContent = 'Submit';

    allFieldSections.forEach(t => {
      const el = document.getElementById(`fields-${t}`);
      if (el) el.classList.toggle('hidden', t !== type);
    });

    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    const firstInput = modal.querySelector<HTMLInputElement>('input[name="name"]');
    setTimeout(() => firstInput?.focus(), 50);
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    activeType = '';
  }

  backdrop.addEventListener('click', closeModal);
  closeBtn.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  document.querySelectorAll<HTMLButtonElement>('[data-modal]').forEach(btn => {
    btn.addEventListener('click', () => openModal(btn.dataset.modal!));
  });

  submitBtn.addEventListener('click', async () => {
    if (!activeType) return;

    const nameVal = (document.getElementById('f-name') as HTMLInputElement).value.trim();
    const emailVal = (document.getElementById('f-email') as HTMLInputElement).value.trim();

    if (!nameVal || !emailVal) {
      statusEl.textContent = 'Please fill in your name and email.';
      statusEl.className = 'text-red-400 text-sm mt-3 text-center';
      return;
    }

    const payload: Record<string, string | null> = {
      partnership_type: activeType,
      name: nameVal,
      email: emailVal,
      company: (document.getElementById('f-company') as HTMLInputElement).value.trim() || null,
      country: (document.getElementById('f-country') as HTMLInputElement).value.trim() || null,
    };

    const getVal = (id: string): string | null => {
      const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
      return el?.value?.trim() || null;
    };

    if (activeType === 'strategic') {
      payload.project_type = getVal('f-project-type');
      payload.geography = getVal('f-geography');
      payload.collaboration_goals = getVal('f-collab-goals');
    } else if (activeType === 'investment') {
      payload.investment_size = getVal('f-investment-size');
      payload.investment_thesis = getVal('f-thesis');
      payload.target_returns = getVal('f-returns');
    } else if (activeType === 'epc') {
      payload.capabilities = getVal('f-capabilities');
      payload.regions_of_interest = getVal('f-regions');
      payload.relevant_experience = getVal('f-experience');
    } else if (activeType === 'technology') {
      payload.products_services = getVal('f-products');
      payload.scale_of_supply = getVal('f-scale');
      payload.message = getVal('f-tech-message');
    } else if (activeType === 'careers') {
      payload.message = getVal('f-careers-message');
    } else if (activeType === 'other') {
      payload.message = getVal('f-other-message');
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const { error } = await supabase.from('partner_inquiries').insert(payload);

    if (error) {
      statusEl.textContent = 'Something went wrong. Please try again.';
      statusEl.className = 'text-red-400 text-sm mt-3 text-center';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit';
    } else {
      statusEl.textContent = "Thank you — we'll be in touch soon.";
      statusEl.className = 'text-emerald-400 text-sm mt-3 text-center';
      submitBtn.textContent = 'Sent!';
      setTimeout(closeModal, 2500);
    }
  });
</script>
